# REQUIRED in production — dashboard login password
# Without this, BugReel runs in dev mode with no authentication
DASHBOARD_PASSWORD=change-me-to-secure-password

# Server
PORT=3500
HOST=0.0.0.0

# Data directory (recordings, frames, SQLite database)
DATA_DIR=./data

# Dashboard URL (used for share links, invite links, embed URLs)
# Set this to your public-facing URL in production
# DASHBOARD_URL=https://your-bugreel.example.com

# AI Services (optional — for transcription and analysis)
# Any OpenAI-compatible endpoint works (OpenAI, Azure, Ollama, etc.)
WHISPER_URL=https://api.openai.com/v1/audio/transcriptions
GPT_URL=https://api.openai.com/v1/chat/completions
GPT_API_KEY=sk-your-openai-key
GPT_MODEL=gpt-4o-mini

# Tracker (configured via dashboard UI — these are legacy env overrides)
TRACKER_TYPE=none
TRACKER_URL=
TRACKER_TOKEN=
TRACKER_PROJECT=

# Auth
AUTH_SALT=change-this-to-random-string

# License (optional — defaults to community tier)
# Use a JWT key for production, or dev-team / dev-enterprise for local development
LICENSE_KEY=

# Branding / White-Label (optional — see docs/branding.md)
# These are defaults; can be overridden via Settings UI in the dashboard.
# BRAND_NAME=BugReel
# BRAND_URL=https://bugreel.io
# BRAND_LOGO_URL=
# BRAND_LOGO_LINK=

# Analytics (optional — inject counters into dashboard and embed pages)
# These are defaults; can be overridden via Settings UI in the dashboard.
# ANALYTICS_YANDEX_METRIKA_ID=
# ANALYTICS_GTAG_ID=

# Limits
MAX_VIDEO_SIZE=104857600
MAX_VIDEO_DURATION=300
MAX_SCREENSHOTS=10

# Feedback — "Report a problem" button in the dashboard.
# When set, the dashboard shows the button and POSTs user feedback to this URL.
# The webhook receives JSON: {source, type, message, page_url, user_agent, user_email, user_name, brand, timestamp}
# FEEDBACK_WEBHOOK_URL=
