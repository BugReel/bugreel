---
import Base from '../layouts/Base.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Terms of Service — BugReel',
  description: 'BugReel terms of service. License terms, acceptable use, self-hosted disclaimer, and legal information.',
  url: 'https://bugreel.io/terms',
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bugreel.io' },
      { '@type': 'ListItem', position: 2, name: 'Terms of Service', item: 'https://bugreel.io/terms' },
    ],
  },
};
---

<Base
  title="Terms of Service — BugReel"
  description="BugReel terms of service. License terms, acceptable use, self-hosted disclaimer, and legal information."
  schema={schema}
>
  <div class="legal-header section-sm">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>Terms of Service</span>
      </nav>
    </div>
  </div>

  <section class="section-sm">
    <div class="container legal-container">
      <h1>Terms of Service</h1>
      <p class="legal-updated">Last updated: March 2026</p>

      <div class="legal-content">
        <section>
          <h2>1. Acceptance of Terms</h2>
          <p>
            By accessing or using BugReel software, the Chrome extension, or this website
            (bugreel.io), you agree to be bound by these Terms of Service. If you do not agree
            to these terms, do not use the software or website.
          </p>
        </section>

        <section>
          <h2>2. License</h2>
          <p>
            BugReel is licensed under the Business Source License (BSL). The Community edition
            is free to use for teams of up to 5 users. The Team and Enterprise editions require
            a valid license key.
          </p>
          <p>
            The BSL allows you to use, modify, and self-host BugReel. You may not offer BugReel
            as a managed service to third parties without a separate commercial agreement. Full
            license terms are available in the <code>LICENSE</code> file in the
            <a href="https://github.com/BugReel/bugreel" target="_blank" rel="noopener">GitHub repository</a>.
          </p>
        </section>

        <section>
          <h2>3. Self-Hosted Disclaimer</h2>
          <p>
            BugReel is designed to be self-hosted on your own infrastructure. You are solely
            responsible for:
          </p>
          <ul>
            <li>Server provisioning, maintenance, and security</li>
            <li>Data backups and disaster recovery</li>
            <li>Network configuration and access control</li>
            <li>Keeping the software up to date</li>
            <li>Compliance with applicable laws regarding data you store</li>
          </ul>
          <p>
            We do not provide hosting, uptime guarantees, or SLAs for self-hosted installations.
            The software is provided for you to run on your own terms.
          </p>
        </section>

        <section>
          <h2>4. Acceptable Use</h2>
          <p>You agree not to:</p>
          <ul>
            <li>Use BugReel for any unlawful purpose</li>
            <li>Redistribute or resell BugReel as a hosted service without authorization</li>
            <li>Remove or alter any license notices, copyright statements, or attribution</li>
            <li>Attempt to circumvent license key validation</li>
            <li>Use the software to infringe on the rights of others</li>
          </ul>
        </section>

        <section>
          <h2>5. Intellectual Property</h2>
          <p>
            BugReel, its logo, documentation, and associated materials are the intellectual
            property of the BugReel project. The BSL license grants you specific rights to use
            and modify the software, but does not transfer ownership.
          </p>
          <p>
            Bug reports, recordings, and data you create using BugReel belong to you. We claim
            no ownership over content generated by your use of the software.
          </p>
        </section>

        <section>
          <h2>6. Limitation of Liability</h2>
          <p>
            BugReel is provided "as is" without warranty of any kind, express or implied,
            including but not limited to warranties of merchantability, fitness for a particular
            purpose, and non-infringement.
          </p>
          <p>
            In no event shall the BugReel project, its authors, or contributors be liable for
            any direct, indirect, incidental, special, exemplary, or consequential damages
            arising from the use of or inability to use the software. This includes, but is not
            limited to, data loss, business interruption, or service downtime on your self-hosted
            installation.
          </p>
        </section>

        <section>
          <h2>7. Termination</h2>
          <p>
            You may stop using BugReel at any time by removing the software from your server
            and uninstalling the Chrome extension.
          </p>
          <p>
            We may revoke your license key if you violate these terms. Upon revocation, Team and
            Enterprise features will be disabled, but the Community edition functionality will
            continue to work.
          </p>
        </section>

        <section>
          <h2>8. Changes to Terms</h2>
          <p>
            We may update these terms from time to time. Changes will be posted on this page
            with an updated revision date. Continued use of BugReel after changes constitutes
            acceptance of the new terms.
          </p>
        </section>

        <section>
          <h2>9. Contact</h2>
          <p>
            If you have questions about these terms, contact us at
            <a href="mailto:hello@bugreel.io">hello@bugreel.io</a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</Base>

<style>
  .legal-header {
    padding-top: 32px;
    padding-bottom: 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  .breadcrumb span {
    color: var(--color-text-dim);
  }

  .breadcrumb span:last-child {
    color: var(--color-text);
  }

  .legal-container {
    max-width: 720px;
  }

  .legal-container h1 {
    margin-bottom: 8px;
  }

  .legal-updated {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    margin-bottom: 48px;
  }

  .legal-content section {
    margin-bottom: 40px;
  }

  .legal-content h2 {
    font-size: 1.25rem;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
  }

  .legal-content p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .legal-content ul {
    color: var(--color-text-muted);
    line-height: 1.7;
    padding-left: 24px;
    margin-bottom: 16px;
  }

  .legal-content li {
    margin-bottom: 8px;
  }

  .legal-content a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .legal-content a:hover {
    text-decoration: underline;
  }

  .legal-content code {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', Menlo, Consolas, monospace;
    font-size: 0.8125rem;
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }
</style>
