  const CATEGORY_ORDER: DodCategoryKey[] = [
    'code-quality', 'testing', 'ci-cd', 'documentation', 'security',
    'accessibility', 'monitoring', 'performance', 'feature-flags',
    'design-review', 'db-migration', 'api-docs', 'product',
  ];

  const PRACTICE_LIST: PracticeKey[] = [
    'code-review', 'automated-testing', 'ci-cd', 'performance-testing',
    'security-review', 'accessibility', 'documentation', 'monitoring',
    'feature-flags', 'design-review', 'db-migration', 'api-docs',
  ];

  const PROJECT_TYPES: ProjectType[] = ['web', 'mobile', 'api', 'data-pipeline', 'desktop'];

  const PROJECT_LABELS: Record<ProjectType, string> = {
    web: 'Web Application',
    mobile: 'Mobile App',
    api: 'API / Microservice',
    'data-pipeline': 'Data Pipeline',
    desktop: 'Desktop Application',
  };

  // --- State ---
  let selectedProjectType: ProjectType | null = null;
  let selectedPractices: Set<PracticeKey> = new Set();
  let checkedItems: Set<string> = new Set();
  let customItems: Record<string, string[]> = {}; // categoryKey -> custom texts

  // --- DOM ---
  const projectTypeGrid = document.getElementById('project-type-grid')!;
  const practiceGrid = document.getElementById('practice-grid')!;
  const step2 = document.getElementById('step-2')!;
  const step3 = document.getElementById('step-3')!;
  const checklistOutput = document.getElementById('checklist-output')!;
  const progressBarFill = document.getElementById('progress-bar-fill')!;
  const progressLabel = document.getElementById('progress-label')!;
  const copyMdBtn = document.getElementById('copy-md-btn')!;
  const copyMdText = document.getElementById('copy-md-text')!;
  const downloadMdBtn = document.getElementById('download-md-btn')!;
  const resetBtn = document.getElementById('reset-btn')!;
  const selectAllBtn = document.getElementById('select-all-btn')!;

  const projectTypeCards = projectTypeGrid.querySelectorAll('.app-type-card');
  const practiceCards = practiceGrid.querySelectorAll('.category-card');

  // --- localStorage ---
  function saveState() {
    try {
      const state = {
        projectType: selectedProjectType,
        practices: Array.from(selectedPractices),
        checked: Array.from(checkedItems),
        customItems: customItems,
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch (e) { /* silent */ }
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const state = JSON.parse(raw);

      if (state.projectType && PROJECT_TYPES.includes(state.projectType)) {
        selectedProjectType = state.projectType;
        projectTypeCards.forEach(card => {
          card.classList.toggle('selected', (card as HTMLElement).dataset.type === selectedProjectType);
        });
        step2.classList.remove('step-disabled');
        step2.classList.add('step-active');
      }

      if (state.practices && Array.isArray(state.practices)) {
        state.practices.forEach((p: string) => {
          if (PRACTICE_LIST.includes(p as PracticeKey)) {
            selectedPractices.add(p as PracticeKey);
          }
        });
        practiceCards.forEach(card => {
          card.classList.toggle('selected', selectedPractices.has((card as HTMLElement).dataset.practice as PracticeKey));
        });
      }

      if (state.checked && Array.isArray(state.checked)) {
        state.checked.forEach((id: string) => checkedItems.add(id));
      }

      if (state.customItems && typeof state.customItems === 'object') {
        customItems = state.customItems;
      }

      updateSelectAllBtn();

      if (selectedProjectType) {
        step3.classList.remove('step-disabled');
        step3.classList.add('step-active');
        renderChecklist();
      }
    } catch (e) { /* silent */ }
  }

  // --- Project Type Selection ---
  projectTypeCards.forEach(card => {
    card.addEventListener('click', () => {
      const type = (card as HTMLElement).dataset.type as ProjectType;

      if (selectedProjectType !== type) {
        checkedItems.clear();
      }

      selectedProjectType = type;
      projectTypeCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');

      // Enable step 2
      step2.classList.remove('step-disabled');
      step2.classList.add('step-active');

      // Always show step 3 when project type is selected (code quality + product always visible)
      step3.classList.remove('step-disabled');
      step3.classList.add('step-active');
      renderChecklist();

      saveState();
    });
  });

  // --- Practice Selection ---
  practiceCards.forEach(card => {
    card.addEventListener('click', () => {
      const practice = (card as HTMLElement).dataset.practice as PracticeKey;

      if (selectedPractices.has(practice)) {
        selectedPractices.delete(practice);
        card.classList.remove('selected');
      } else {
        selectedPractices.add(practice);
        card.classList.add('selected');
      }

      updateSelectAllBtn();

      if (selectedProjectType) {
        step3.classList.remove('step-disabled');
        step3.classList.add('step-active');
        renderChecklist();
      }

      saveState();
    });
  });

  // --- Select All / Deselect All ---
  selectAllBtn.addEventListener('click', () => {
    const allSelected = selectedPractices.size === PRACTICE_LIST.length;
    if (allSelected) {
      selectedPractices.clear();
      practiceCards.forEach(c => c.classList.remove('selected'));
    } else {
      PRACTICE_LIST.forEach(p => selectedPractices.add(p));
      practiceCards.forEach(c => c.classList.add('selected'));
    }

    updateSelectAllBtn();

    if (selectedProjectType) {
      step3.classList.remove('step-disabled');
      step3.classList.add('step-active');
      renderChecklist();
    }

    saveState();
  });

  function updateSelectAllBtn() {
    const allSelected = selectedPractices.size === PRACTICE_LIST.length;
    selectAllBtn.textContent = allSelected ? 'Deselect All' : 'Select All';
  }

  // --- Get visible categories ---
  function getVisibleCategories(): DodCategoryKey[] {
    return CATEGORY_ORDER.filter(catKey => {
      const cat = DOD_CATEGORIES[catKey];
      // Always-visible categories (requiredPractice is null)
      if (cat.requiredPractice === null) return true;
      // Practice-conditional categories
      return selectedPractices.has(cat.requiredPractice);
    });
  }

  // --- Render Checklist ---
  function renderChecklist() {
    if (!selectedProjectType) {
      checklistOutput.innerHTML = '';
      updateProgress(0, 0);
      return;
    }

    const visibleCategories = getVisibleCategories();

    let html = '';
    let totalItems = 0;
    let checkedCount = 0;

    visibleCategories.forEach(catKey => {
      const cat = DOD_CATEGORIES[catKey];
      const items = cat.items[selectedProjectType!] || [];
      const customs = customItems[catKey] || [];
      const allItems = items.length + customs.length;
      if (allItems === 0 && customs.length === 0) return;

      let sectionChecked = 0;
      items.forEach((_, idx) => {
        const id = `${catKey}-${idx}`;
        if (checkedItems.has(id)) sectionChecked++;
      });
      customs.forEach((_, idx) => {
        const id = `${catKey}-custom-${idx}`;
        if (checkedItems.has(id)) sectionChecked++;
      });

      totalItems += allItems;
      checkedCount += sectionChecked;

      html += `<div class="cl-section" data-category="${catKey}">`;
      html += `<div class="cl-section-header" data-toggle="${catKey}">`;
      html += `<svg class="cl-section-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      html += `<span class="cl-section-title">${escapeHtml(cat.label)}</span>`;
      html += `<span class="cl-section-count" data-count="${catKey}">${sectionChecked}/${allItems}</span>`;
      html += `</div>`;
      html += `<div class="cl-section-body" data-body="${catKey}">`;

      // Built-in items
      items.forEach((text, idx) => {
        const id = `${catKey}-${idx}`;
        const isChecked = checkedItems.has(id);
        html += `<div class="cl-item${isChecked ? ' checked' : ''}" data-id="${id}">`;
        html += `<div class="cl-checkbox">`;
        html += `<svg class="cl-checkmark" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 6l2.5 2.5 4.5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        html += `</div>`;
        html += `<span class="cl-text">${escapeHtml(text)}</span>`;
        html += `</div>`;
      });

      // Custom items
      customs.forEach((text, idx) => {
        const id = `${catKey}-custom-${idx}`;
        const isChecked = checkedItems.has(id);
        html += `<div class="cl-item custom-item${isChecked ? ' checked' : ''}" data-id="${id}" data-custom-cat="${catKey}" data-custom-idx="${idx}">`;
        html += `<div class="cl-checkbox">`;
        html += `<svg class="cl-checkmark" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 6l2.5 2.5 4.5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        html += `</div>`;
        html += `<span class="cl-text">${escapeHtml(text)}</span>`;
        html += `<button class="cl-delete-btn" data-del-cat="${catKey}" data-del-idx="${idx}" type="button" title="Remove custom item">`;
        html += `<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3.5 3.5l7 7M10.5 3.5l-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>`;
        html += `</button>`;
        html += `</div>`;
      });

      // Add custom item input
      html += `<div class="cl-add-item">`;
      html += `<input class="cl-add-input" data-add-cat="${catKey}" type="text" placeholder="Add custom item..." />`;
      html += `<button class="cl-add-btn" data-add-btn="${catKey}" type="button">Add</button>`;
      html += `</div>`;

      html += `</div></div>`;
    });

    checklistOutput.innerHTML = html;
    updateProgress(checkedCount, totalItems);

    // Bind click events for items
    checklistOutput.querySelectorAll('.cl-item').forEach(item => {
      item.addEventListener('click', (e) => {
        // Don't toggle when clicking delete button
        if ((e.target as HTMLElement).closest('.cl-delete-btn')) return;

        const id = (item as HTMLElement).dataset.id!;
        if (checkedItems.has(id)) {
          checkedItems.delete(id);
          item.classList.remove('checked');
        } else {
          checkedItems.add(id);
          item.classList.add('checked');
        }
        updateProgressFromDOM();
        saveState();
      });
    });

    // Bind click events for section collapse
    checklistOutput.querySelectorAll('.cl-section-header').forEach(header => {
      header.addEventListener('click', () => {
        const catKey = (header as HTMLElement).dataset.toggle!;
        const body = checklistOutput.querySelector(`[data-body="${catKey}"]`) as HTMLElement;
        if (!body) return;
        const isCollapsed = body.classList.contains('collapsed');
        if (isCollapsed) {
          body.classList.remove('collapsed');
          header.classList.remove('collapsed');
        } else {
          body.classList.add('collapsed');
          header.classList.add('collapsed');
        }
      });
    });

    // Bind add custom item buttons
    checklistOutput.querySelectorAll('.cl-add-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const catKey = (btn as HTMLElement).dataset.addBtn!;
        const input = checklistOutput.querySelector(`[data-add-cat="${catKey}"]`) as HTMLInputElement;
        if (!input) return;
        const text = input.value.trim();
        if (!text) return;
        if (!customItems[catKey]) customItems[catKey] = [];
        customItems[catKey].push(text);
        input.value = '';
        saveState();
        renderChecklist();
      });
    });

    // Bind enter key on add inputs
    checklistOutput.querySelectorAll('.cl-add-input').forEach(input => {
      input.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
          const catKey = (input as HTMLElement).dataset.addCat!;
          const btn = checklistOutput.querySelector(`[data-add-btn="${catKey}"]`) as HTMLButtonElement;
          if (btn) btn.click();
        }
      });
    });

    // Bind delete custom item buttons
    checklistOutput.querySelectorAll('.cl-delete-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const catKey = (btn as HTMLElement).dataset.delCat!;
        const idx = parseInt((btn as HTMLElement).dataset.delIdx!, 10);
        if (customItems[catKey]) {
          // Remove checked state for this and reindex subsequent custom items
          const oldId = `${catKey}-custom-${idx}`;
          checkedItems.delete(oldId);
          customItems[catKey].splice(idx, 1);
          if (customItems[catKey].length === 0) delete customItems[catKey];
          // Reindex checked items for this category
          reindexCustomChecked(catKey);
        }
        saveState();
        renderChecklist();
      });
    });
  }

  function reindexCustomChecked(catKey: string) {
    // Clear all custom checked for this category and re-apply based on new indices
    const toRemove: string[] = [];
    checkedItems.forEach(id => {
      if (id.startsWith(`${catKey}-custom-`)) toRemove.push(id);
    });
    toRemove.forEach(id => checkedItems.delete(id));
    // Note: after deletion and reindex, previously checked custom items lose their state
    // This is acceptable UX since the list is reordered
  }

  // --- Progress ---
  function updateProgress(checked: number, total: number) {
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
    progressBarFill.style.width = `${pct}%`;

    progressBarFill.classList.remove('progress-mid', 'progress-high');
    if (pct >= 100) {
      progressBarFill.classList.add('progress-high');
    } else if (pct >= 50) {
      progressBarFill.classList.add('progress-mid');
    }

    progressLabel.textContent = `${checked} / ${total} items checked`;
  }

  function updateProgressFromDOM() {
    const allItems = checklistOutput.querySelectorAll('.cl-item');
    const checkedCount = checklistOutput.querySelectorAll('.cl-item.checked').length;
    updateProgress(checkedCount, allItems.length);

    // Update section counts
    getVisibleCategories().forEach(catKey => {
      const section = checklistOutput.querySelector(`[data-category="${catKey}"]`);
      if (!section) return;
      const items = section.querySelectorAll('.cl-item');
      const checked = section.querySelectorAll('.cl-item.checked');
      const countEl = section.querySelector(`[data-count="${catKey}"]`);
      if (countEl) {
        countEl.textContent = `${checked.length}/${items.length}`;
      }
    });
  }

  // --- Generate Markdown ---
  function generateMarkdown(): string {
    if (!selectedProjectType) return '';

    let md = `# Definition of Done -- ${PROJECT_LABELS[selectedProjectType]}\n\n`;

    const visibleCategories = getVisibleCategories();

    visibleCategories.forEach(catKey => {
      const cat = DOD_CATEGORIES[catKey];
      const items = cat.items[selectedProjectType!] || [];
      const customs = customItems[catKey] || [];
      if (items.length === 0 && customs.length === 0) return;

      md += `## ${cat.label}\n\n`;
      items.forEach((text, idx) => {
        const id = `${catKey}-${idx}`;
        const mark = checkedItems.has(id) ? 'x' : ' ';
        md += `- [${mark}] ${text}\n`;
      });
      customs.forEach((text, idx) => {
        const id = `${catKey}-custom-${idx}`;
        const mark = checkedItems.has(id) ? 'x' : ' ';
        md += `- [${mark}] ${text}\n`;
      });
      md += '\n';
    });

    md += `---\n*Generated with [BugReel Definition of Done Generator](https://bugreel.io/tools/definition-of-done)*\n`;
    return md;
  }

  // --- Copy ---
  copyMdBtn.addEventListener('click', async () => {
    const md = generateMarkdown();
    if (!md) return;
    try {
      await navigator.clipboard.writeText(md);
      copyMdBtn.classList.add('copied');
      copyMdText.textContent = 'Copied!';
      setTimeout(() => {
        copyMdBtn.classList.remove('copied');
        copyMdText.textContent = 'Copy as Markdown';
      }, 2000);
    } catch {
      const textArea = document.createElement('textarea');
      textArea.value = md;
      textArea.style.position = 'fixed';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      copyMdBtn.classList.add('copied');
      copyMdText.textContent = 'Copied!';
      setTimeout(() => {
        copyMdBtn.classList.remove('copied');
        copyMdText.textContent = 'Copy as Markdown';
      }, 2000);
    }
  });

  // --- Download ---
  downloadMdBtn.addEventListener('click', () => {
    const md = generateMarkdown();
    if (!md) return;
    const slug = selectedProjectType || 'checklist';
    const filename = `definition-of-done-${slug}.md`;
    const blob = new Blob([md], { type: 'text/markdown;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // --- Reset ---
  resetBtn.addEventListener('click', () => {
    checkedItems.clear();
    checklistOutput.querySelectorAll('.cl-item.checked').forEach(item => {
      item.classList.remove('checked');
    });
    updateProgressFromDOM();
    saveState();
  });

  // --- Helpers ---
  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // --- Init ---
  loadState();
</script>
