</style>

<script>
  // ===== Release Readiness Checklist — Client-Side Logic =====

  // --- Data Model ---
  interface CategoryDef {
    name: string;
    questions: number[];
  }

  interface QuestionDef {
    name: string;
    category: number;
  }

  const CATEGORIES: CategoryDef[] = [
    { name: 'Code Quality', questions: [0, 1, 2, 3] },
    { name: 'Testing', questions: [4, 5, 6, 7, 8] },
    { name: 'Infrastructure', questions: [9, 10, 11, 12] },
    { name: 'Documentation', questions: [13, 14, 15, 16] },
    { name: 'Communication', questions: [17, 18, 19] },
    { name: 'Team Readiness', questions: [20, 21, 22] },
  ];

  const QUESTIONS: QuestionDef[] = [
    { name: 'Code Review Status', category: 0 },
    { name: 'Known Critical Bugs', category: 0 },
    { name: 'Feature Freeze', category: 0 },
    { name: 'Technical Debt', category: 0 },
    { name: 'Test Coverage', category: 1 },
    { name: 'Test Suite Results', category: 1 },
    { name: 'Regression Testing', category: 1 },
    { name: 'Performance Testing', category: 1 },
    { name: 'Exploratory Testing', category: 1 },
    { name: 'Deployment Pipeline', category: 2 },
    { name: 'Rollback Plan', category: 2 },
    { name: 'Database Migrations', category: 2 },
    { name: 'Monitoring & Alerting', category: 2 },
    { name: 'Release Notes', category: 3 },
    { name: 'API Documentation', category: 3 },
    { name: 'Internal Runbook', category: 3 },
    { name: 'Changelog', category: 3 },
    { name: 'Stakeholder Communication', category: 4 },
    { name: 'Support Team Briefing', category: 4 },
    { name: 'Customer Communication', category: 4 },
    { name: 'On-Call Team', category: 5 },
    { name: 'Rollback Owner', category: 5 },
    { name: 'Release Window', category: 5 },
  ];

  const TOTAL_QUESTIONS = QUESTIONS.length;
  const MAX_PTS_PER_Q = 3;

  const answers: (number | null)[] = new Array(TOTAL_QUESTIONS).fill(null);
  const answerLabels: (string | null)[] = new Array(TOTAL_QUESTIONS).fill(null);
  let activeCategory = 0;

  // --- DOM References ---
  const progressFill = document.getElementById('progress-fill') as HTMLDivElement;
  const progressLabel = document.getElementById('progress-label') as HTMLSpanElement;
  const questionsContainer = document.getElementById('questions-container')!;
  const resultPanel = document.getElementById('result-panel') as HTMLDivElement;
  const resultCard = document.getElementById('result-card') as HTMLDivElement;
  const resultBreakdown = document.getElementById('result-breakdown')!;
  const resultBlockers = document.getElementById('result-blockers') as HTMLDivElement;
  const blockersList = document.getElementById('blockers-list')!;
  const verdictBadge = document.getElementById('verdict-badge') as HTMLDivElement;
  const verdictIcon = document.getElementById('verdict-icon') as SVGElement;
  const verdictLabel = document.getElementById('verdict-label')!;
  const verdictSummary = document.getElementById('verdict-summary')!;
  const copyAssessmentBtn = document.getElementById('copy-assessment-btn')!;
  const copyAssessmentText = document.getElementById('copy-assessment-text')!;
  const downloadBtn = document.getElementById('download-btn')!;
  const resetBtn = document.getElementById('reset-btn')!;
  const prevBtn = document.getElementById('prev-category-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-category-btn') as HTMLButtonElement;

  const allCategoryTabs = document.querySelectorAll('.category-tab') as NodeListOf<HTMLButtonElement>;
  const allCategoryPanels = document.querySelectorAll('.category-panel') as NodeListOf<HTMLDivElement>;
  const allOptionButtons = questionsContainer.querySelectorAll('.option-row') as NodeListOf<HTMLButtonElement>;
  const allQuestionCards = questionsContainer.querySelectorAll('.question-card') as NodeListOf<HTMLDivElement>;

  // --- Category Navigation ---
  function switchCategory(idx: number) {
    activeCategory = idx;

    allCategoryTabs.forEach((tab, i) => {
      tab.classList.toggle('active', i === idx);
    });

    allCategoryPanels.forEach((panel, i) => {
      panel.classList.toggle('active', i === idx);
    });

    prevBtn.disabled = idx === 0;

    if (idx === CATEGORIES.length - 1) {
      const allAnswered = answers.every(a => a !== null);
      nextBtn.textContent = allAnswered ? 'See Results' : 'Next';
    } else {
      nextBtn.textContent = '';
      nextBtn.innerHTML = 'Next <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    }

    updateNavButtons();
  }

  function updateNavButtons() {
    prevBtn.disabled = activeCategory === 0;

    const isLast = activeCategory === CATEGORIES.length - 1;
    const allAnswered = answers.every(a => a !== null);

    if (isLast && allAnswered) {
      nextBtn.innerHTML = 'See Results <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
    } else if (isLast) {
      nextBtn.innerHTML = 'Next <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      nextBtn.disabled = true;
    } else {
      nextBtn.innerHTML = 'Next <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      nextBtn.disabled = false;
    }
  }

  allCategoryTabs.forEach((tab, i) => {
    tab.addEventListener('click', () => switchCategory(i));
  });

  prevBtn.addEventListener('click', () => {
    if (activeCategory > 0) {
      switchCategory(activeCategory - 1);
      window.scrollTo({ top: questionsContainer.offsetTop - 100, behavior: 'smooth' });
    }
  });

  nextBtn.addEventListener('click', () => {
    const isLast = activeCategory === CATEGORIES.length - 1;
    const allAnswered = answers.every(a => a !== null);

    if (isLast && allAnswered) {
      showResult();
    } else if (!isLast) {
      switchCategory(activeCategory + 1);
      window.scrollTo({ top: questionsContainer.offsetTop - 100, behavior: 'smooth' });
    }
  });

  // --- Scoring ---
  function getCategoryScore(catIdx: number): { earned: number; max: number; pct: number } {
    const cat = CATEGORIES[catIdx];
    const max = cat.questions.length * MAX_PTS_PER_Q;
    let earned = 0;
    for (const qIdx of cat.questions) {
      earned += answers[qIdx] ?? 0;
    }
    const pct = max > 0 ? Math.round((earned / max) * 100) : 0;
    return { earned, max, pct };
  }

  function getCategoryStatus(pct: number): 'green' | 'yellow' | 'red' {
    if (pct >= 80) return 'green';
    if (pct >= 50) return 'yellow';
    return 'red';
  }

  function getCategoryStatusLabel(status: string): string {
    switch (status) {
      case 'green': return 'Ready';
      case 'yellow': return 'Caution';
      case 'red': return 'Blocked';
      default: return '';
    }
  }

  function getOverallVerdict(statuses: string[]): 'go' | 'caution' | 'nogo' {
    if (statuses.includes('red')) return 'nogo';
    const yellowCount = statuses.filter(s => s === 'yellow').length;
    if (yellowCount > 2) return 'nogo';
    if (yellowCount > 0) return 'caution';
    return 'go';
  }

  // --- Progress ---
  function updateProgress() {
    const answered = answers.filter(a => a !== null).length;
    const pct = (answered / TOTAL_QUESTIONS) * 100;
    progressFill.style.width = pct + '%';
    progressLabel.textContent = `${answered} of ${TOTAL_QUESTIONS} answered`;

    // Update tab counts and dots
    CATEGORIES.forEach((cat, i) => {
      const answeredInCat = cat.questions.filter(q => answers[q] !== null).length;
      const countEl = document.getElementById(`tab-count-${i}`);
      const dotEl = document.getElementById(`tab-dot-${i}`);
      if (countEl) countEl.textContent = `${answeredInCat}/${cat.questions.length}`;

      if (dotEl) {
        dotEl.className = 'tab-dot';
        if (answeredInCat === cat.questions.length) {
          const score = getCategoryScore(i);
          const status = getCategoryStatus(score.pct);
          dotEl.classList.add(`dot-${status}`);
        }
      }
    });

    updateNavButtons();
  }

  // --- Option Click ---
  function getOptionColor(value: number): string {
    if (value === 3) return 'selected-green';
    if (value === 2) return 'selected-yellow';
    return 'selected-red';
  }

  function handleOptionClick(btn: HTMLButtonElement) {
    const qIdx = parseInt(btn.getAttribute('data-question')!);
    const value = parseInt(btn.getAttribute('data-value')!);
    const label = btn.getAttribute('data-label')!;

    // Deselect siblings
    const siblings = questionsContainer.querySelectorAll(`.option-row[data-question="${qIdx}"]`);
    siblings.forEach(s => {
      s.classList.remove('selected', 'selected-green', 'selected-yellow', 'selected-red');
    });

    // Select with color
    btn.classList.add('selected', getOptionColor(value));

    // Store answer
    answers[qIdx] = value;
    answerLabels[qIdx] = label;

    // Mark card answered
    const card = questionsContainer.querySelector(`.question-card[data-question="${qIdx}"]`);
    if (card) card.classList.add('answered');

    updateProgress();

    // Auto-advance to next category if all questions in current category are answered
    const currentCat = CATEGORIES[activeCategory];
    const allInCatAnswered = currentCat.questions.every(q => answers[q] !== null);
    if (allInCatAnswered && activeCategory < CATEGORIES.length - 1) {
      setTimeout(() => {
        switchCategory(activeCategory + 1);
        window.scrollTo({ top: questionsContainer.offsetTop - 100, behavior: 'smooth' });
      }, 400);
    }

    // Check if all answered - show results automatically
    const allAnswered = answers.every(a => a !== null);
    if (allAnswered && activeCategory === CATEGORIES.length - 1) {
      setTimeout(() => showResult(), 500);
    }
  }

  allOptionButtons.forEach(btn => {
    btn.addEventListener('click', () => handleOptionClick(btn));
  });

  // --- SVG Icons for Verdict ---
  function getVerdictSVG(verdict: string): string {
    switch (verdict) {
      case 'go':
        return '<circle cx="16" cy="16" r="12" stroke="#22c55e" stroke-width="2" fill="none"/><path d="M11 16l3 3 7-7" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>';
      case 'caution':
        return '<path d="M16 4L2 28h28L16 4z" stroke="#eab308" stroke-width="2" fill="none"/><path d="M16 12v8" stroke="#eab308" stroke-width="2.5" stroke-linecap="round"/><circle cx="16" cy="24" r="1.5" fill="#eab308"/>';
      case 'nogo':
        return '<circle cx="16" cy="16" r="12" stroke="#ef4444" stroke-width="2" fill="none"/><path d="M11 11l10 10M21 11l-10 10" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round"/>';
      default:
        return '';
    }
  }

  // --- Show Result ---
  function showResult() {
    const catStatuses: string[] = [];
    let breakdownHtml = '';
    const blockers: string[] = [];

    CATEGORIES.forEach((cat, i) => {
      const score = getCategoryScore(i);
      const status = getCategoryStatus(score.pct);
      catStatuses.push(status);

      breakdownHtml += `
        <div class="breakdown-category">
          <div class="breakdown-left">
            <span class="breakdown-dot dot-${status}"></span>
            <span class="breakdown-cat-name">${cat.name}</span>
          </div>
          <div class="breakdown-right">
            <span class="breakdown-status status-${status}">${getCategoryStatusLabel(status)}</span>
            <span class="breakdown-pct">${score.pct}%</span>
          </div>
        </div>
      `;

      // Collect blockers (questions answered with 0 points)
      if (status === 'red' || status === 'yellow') {
        for (const qIdx of cat.questions) {
          if (answers[qIdx] === 0) {
            blockers.push(`<strong>${cat.name}</strong> / ${QUESTIONS[qIdx].name}: ${answerLabels[qIdx]}`);
          }
        }
      }
    });

    resultBreakdown.innerHTML = breakdownHtml;

    // Blockers
    if (blockers.length > 0) {
      blockersList.innerHTML = blockers.map(b => `<li>${b}</li>`).join('');
      resultBlockers.hidden = false;
    } else {
      resultBlockers.hidden = true;
    }

    // Overall verdict
    const verdict = getOverallVerdict(catStatuses);

    verdictBadge.className = 'verdict-badge';
    verdictBadge.classList.add(`verdict-${verdict}`);

    verdictIcon.innerHTML = getVerdictSVG(verdict);

    switch (verdict) {
      case 'go':
        verdictLabel.textContent = 'GO';
        verdictSummary.textContent = 'All categories are green. Your release is ready to ship. Proceed with the deployment plan.';
        break;
      case 'caution':
        verdictLabel.textContent = 'CAUTION';
        verdictSummary.textContent = 'Some categories need attention. Review the yellow items below and decide if the risks are acceptable before proceeding.';
        break;
      case 'nogo':
        verdictLabel.textContent = 'NO-GO';
        verdictSummary.textContent = 'Critical gaps detected. Resolve the blockers listed below before attempting to release. Shipping now carries significant risk.';
        break;
    }

    resultPanel.hidden = false;

    setTimeout(() => {
      resultPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }, 100);
  }

  // --- Build Assessment Markdown ---
  function buildAssessmentMarkdown(): string {
    const catStatuses: string[] = [];
    let md = '# Release Readiness Assessment\n\n';

    const verdict = getOverallVerdict(
      CATEGORIES.map((_, i) => getCategoryStatus(getCategoryScore(i).pct))
    );

    const verdictText = verdict === 'go' ? 'GO' : verdict === 'caution' ? 'CAUTION' : 'NO-GO';
    md += `## Overall Verdict: ${verdictText}\n\n`;

    CATEGORIES.forEach((cat, i) => {
      const score = getCategoryScore(i);
      const status = getCategoryStatus(score.pct);
      const statusLabel = getCategoryStatusLabel(status);
      catStatuses.push(status);

      md += `### ${cat.name} - ${statusLabel} (${score.pct}%)\n\n`;

      for (const qIdx of cat.questions) {
        const pts = answers[qIdx] ?? 0;
        const label = answerLabels[qIdx] || 'Not answered';
        const icon = pts === 3 ? '[PASS]' : pts === 2 ? '[WARN]' : '[FAIL]';
        md += `- ${icon} ${QUESTIONS[qIdx].name}: ${label}\n`;
      }
      md += '\n';
    });

    // Blockers
    const blockers: string[] = [];
    CATEGORIES.forEach((cat, i) => {
      for (const qIdx of cat.questions) {
        if (answers[qIdx] === 0) {
          blockers.push(`${cat.name} / ${QUESTIONS[qIdx].name}: ${answerLabels[qIdx]}`);
        }
      }
    });

    if (blockers.length > 0) {
      md += '## Blockers\n\n';
      blockers.forEach(b => {
        md += `- ${b}\n`;
      });
      md += '\n';
    }

    md += '---\nGenerated by BugReel Release Readiness Checklist (bugreel.io/tools/release-checklist)\n';
    return md;
  }

  // --- Copy Assessment ---
  copyAssessmentBtn.addEventListener('click', async () => {
    const text = buildAssessmentMarkdown();
    try {
      await navigator.clipboard.writeText(text);
      copyAssessmentBtn.classList.add('copied');
      copyAssessmentText.textContent = 'Copied!';
      setTimeout(() => {
        copyAssessmentBtn.classList.remove('copied');
        copyAssessmentText.textContent = 'Copy Assessment Report';
      }, 2000);
    } catch {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
      copyAssessmentBtn.classList.add('copied');
      copyAssessmentText.textContent = 'Copied!';
      setTimeout(() => {
        copyAssessmentBtn.classList.remove('copied');
        copyAssessmentText.textContent = 'Copy Assessment Report';
      }, 2000);
    }
  });

  // --- Download .md ---
  downloadBtn.addEventListener('click', () => {
    const text = buildAssessmentMarkdown();
    const blob = new Blob([text], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'release-readiness-assessment.md';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // --- Reset ---
  resetBtn.addEventListener('click', () => {
    for (let i = 0; i < TOTAL_QUESTIONS; i++) {
      answers[i] = null;
      answerLabels[i] = null;
    }

    allOptionButtons.forEach(btn => {
      btn.classList.remove('selected', 'selected-green', 'selected-yellow', 'selected-red');
    });

    allQuestionCards.forEach(card => card.classList.remove('answered'));

    resultPanel.hidden = true;

    switchCategory(0);
    updateProgress();

    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // --- Initial State ---
  switchCategory(0);
  updateProgress();
</script>
