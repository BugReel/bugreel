---
import Base from '../../layouts/Base.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Release Readiness Checklist',
    description: 'Is your release ready to ship? Assess code, testing, infrastructure, documentation, and team readiness. Get a clear Go / No-Go recommendation.',
    url: 'https://bugreel.io/tools/release-checklist',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    browserRequirements: 'Requires JavaScript',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    creator: {
      '@type': 'Organization',
      name: 'BugReel',
      url: 'https://bugreel.io',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bugreel.io' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://bugreel.io/tools' },
      { '@type': 'ListItem', position: 3, name: 'Release Checklist', item: 'https://bugreel.io/tools/release-checklist' },
    ],
  },
];
---

<Base
  title="Release Readiness Checklist — Go/No-Go Assessment | BugReel"
  description="Is your release ready to ship? Assess code, testing, infrastructure, documentation, and team readiness. Get a clear Go / No-Go recommendation. Free, no signup required."
  schema={schema}
>
  <!-- Breadcrumb -->
  <div class="page-header section-sm">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/tools">Tools</a>
        <span aria-hidden="true">/</span>
        <span>Release Checklist</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <span class="badge badge-success">Free &middot; No Signup</span>
        <h1>Release Readiness Checklist</h1>
        <p class="hero-subtitle">Is your release ready to ship? Assess code, testing, infrastructure, documentation, and team readiness. Get a clear Go / No-Go recommendation.</p>
      </div>
    </div>
  </section>

  <!-- Checklist -->
  <section class="tool-section">
    <div class="container">

      <!-- Progress -->
      <div class="progress-bar" id="progress-bar">
        <div class="progress-track">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <span class="progress-label" id="progress-label">0 of 24 answered</span>
      </div>

      <!-- Category Tabs -->
      <div class="category-tabs" id="category-tabs">
        <button class="category-tab active" data-category="0" type="button">
          <span class="tab-dot" id="tab-dot-0"></span>
          <span class="tab-label">Code Quality</span>
          <span class="tab-count" id="tab-count-0">0/4</span>
        </button>
        <button class="category-tab" data-category="1" type="button">
          <span class="tab-dot" id="tab-dot-1"></span>
          <span class="tab-label">Testing</span>
          <span class="tab-count" id="tab-count-1">0/5</span>
        </button>
        <button class="category-tab" data-category="2" type="button">
          <span class="tab-dot" id="tab-dot-2"></span>
          <span class="tab-label">Infrastructure</span>
          <span class="tab-count" id="tab-count-2">0/4</span>
        </button>
        <button class="category-tab" data-category="3" type="button">
          <span class="tab-dot" id="tab-dot-3"></span>
          <span class="tab-label">Documentation</span>
          <span class="tab-count" id="tab-count-3">0/4</span>
        </button>
        <button class="category-tab" data-category="4" type="button">
          <span class="tab-dot" id="tab-dot-4"></span>
          <span class="tab-label">Communication</span>
          <span class="tab-count" id="tab-count-4">0/3</span>
        </button>
        <button class="category-tab" data-category="5" type="button">
          <span class="tab-dot" id="tab-dot-5"></span>
          <span class="tab-label">Team Readiness</span>
          <span class="tab-count" id="tab-count-5">0/3</span>
        </button>
      </div>

      <!-- Questions Container -->
      <div class="questions-container" id="questions-container">

        <!-- Category 0: Code Quality -->
        <div class="category-panel active" data-category-panel="0">
          <div class="category-heading">
            <div class="category-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h2>Code Quality</h2>
              <p>Review the state of your codebase before release.</p>
            </div>
          </div>

          <div class="question-card card" data-question="0">
            <div class="question-header">
              <span class="question-number">1</span>
              <div>
                <h3>Code Review Status</h3>
                <p>All code reviewed and merged?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="0" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; all PRs reviewed and merged</span>
              </button>
              <button class="option-row" data-question="0" data-value="2" data-label="Partial" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Partial &mdash; some PRs still pending review</span>
              </button>
              <button class="option-row" data-question="0" data-value="0" data-label="No" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">No &mdash; significant unreviewed code</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="1">
            <div class="question-header">
              <span class="question-number">2</span>
              <div>
                <h3>Known Critical Bugs</h3>
                <p>Any known critical bugs remaining?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="1" data-value="3" data-label="None" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">None &mdash; no known bugs blocking release</span>
              </button>
              <button class="option-row" data-question="1" data-value="2" data-label="1-2 non-critical" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">1-2 non-critical &mdash; minor issues documented</span>
              </button>
              <button class="option-row" data-question="1" data-value="0" data-label="Critical bugs exist" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Critical bugs exist &mdash; known blockers unresolved</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="2">
            <div class="question-header">
              <span class="question-number">3</span>
              <div>
                <h3>Feature Freeze</h3>
                <p>Feature freeze respected?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="2" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; no new features after freeze date</span>
              </button>
              <button class="option-row" data-question="2" data-value="2" data-label="Minor exceptions" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Minor exceptions &mdash; small changes approved</span>
              </button>
              <button class="option-row" data-question="2" data-value="0" data-label="Major changes after freeze" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Major changes after freeze &mdash; scope creep</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="3">
            <div class="question-header">
              <span class="question-number">4</span>
              <div>
                <h3>Technical Debt</h3>
                <p>Technical debt acceptable?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="3" data-value="3" data-label="Clean" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Clean &mdash; no new tech debt introduced</span>
              </button>
              <button class="option-row" data-question="3" data-value="2" data-label="Documented" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Documented &mdash; debt exists but tracked with tickets</span>
              </button>
              <button class="option-row" data-question="3" data-value="0" data-label="Significant" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Significant &mdash; untracked debt may cause issues</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Category 1: Testing -->
        <div class="category-panel" data-category-panel="1">
          <div class="category-heading">
            <div class="category-icon category-icon--testing">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9 5a2 2 0 012-2h2a2 2 0 012 2v0a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9 14l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h2>Testing</h2>
              <p>Verify your test coverage and test results.</p>
            </div>
          </div>

          <div class="question-card card" data-question="4">
            <div class="question-header">
              <span class="question-number">5</span>
              <div>
                <h3>Test Coverage</h3>
                <p>Test coverage adequate?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="4" data-value="3" data-label=">80% coverage" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">&gt;80% &mdash; comprehensive coverage of critical paths</span>
              </button>
              <button class="option-row" data-question="4" data-value="2" data-label="60-80% coverage" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">60-80% &mdash; core flows covered, gaps in edge cases</span>
              </button>
              <button class="option-row" data-question="4" data-value="0" data-label="<60% coverage" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">&lt;60% &mdash; significant areas untested</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="5">
            <div class="question-header">
              <span class="question-number">6</span>
              <div>
                <h3>Test Suite Results</h3>
                <p>All test suites pass?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="5" data-value="3" data-label="All green" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">All green &mdash; every test suite passes</span>
              </button>
              <button class="option-row" data-question="5" data-value="2" data-label="Known flaky tests" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Known flaky tests &mdash; failures are documented and non-blocking</span>
              </button>
              <button class="option-row" data-question="5" data-value="0" data-label="Failures" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Failures &mdash; real test failures not yet resolved</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="6">
            <div class="question-header">
              <span class="question-number">7</span>
              <div>
                <h3>Regression Testing</h3>
                <p>Regression testing completed?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="6" data-value="3" data-label="Full" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Full &mdash; all regression suites executed and passed</span>
              </button>
              <button class="option-row" data-question="6" data-value="2" data-label="Partial" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Partial &mdash; critical paths covered, others skipped</span>
              </button>
              <button class="option-row" data-question="6" data-value="0" data-label="Not done" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Not done &mdash; regression testing has not been run</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="7">
            <div class="question-header">
              <span class="question-number">8</span>
              <div>
                <h3>Performance Testing</h3>
                <p>Performance testing done?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="7" data-value="3" data-label="Passed" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Passed &mdash; performance within acceptable thresholds</span>
              </button>
              <button class="option-row" data-question="7" data-value="2" data-label="Not tested" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Not tested &mdash; no performance tests were run</span>
              </button>
              <button class="option-row" data-question="7" data-value="0" data-label="Degradation found" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Degradation found &mdash; performance regressions detected</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="8">
            <div class="question-header">
              <span class="question-number">9</span>
              <div>
                <h3>Exploratory Testing</h3>
                <p>Exploratory / manual testing done?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="8" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; manual testing completed across key scenarios</span>
              </button>
              <button class="option-row" data-question="8" data-value="2" data-label="Partial" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Partial &mdash; some manual testing, not comprehensive</span>
              </button>
              <button class="option-row" data-question="8" data-value="0" data-label="No" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">No &mdash; no manual or exploratory testing performed</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Category 2: Infrastructure -->
        <div class="category-panel" data-category-panel="2">
          <div class="category-heading">
            <div class="category-icon category-icon--infra">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="2" y="3" width="20" height="6" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <rect x="2" y="15" width="20" height="6" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="6" cy="6" r="1" fill="currentColor"/>
                <circle cx="6" cy="18" r="1" fill="currentColor"/>
                <path d="M12 9v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div>
              <h2>Infrastructure</h2>
              <p>Confirm your deployment and rollback readiness.</p>
            </div>
          </div>

          <div class="question-card card" data-question="9">
            <div class="question-header">
              <span class="question-number">10</span>
              <div>
                <h3>Deployment Pipeline</h3>
                <p>Deployment pipeline tested?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="9" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; pipeline tested end-to-end on staging</span>
              </button>
              <button class="option-row" data-question="9" data-value="2" data-label="Partial" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Partial &mdash; some steps verified, not full run</span>
              </button>
              <button class="option-row" data-question="9" data-value="0" data-label="No" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">No &mdash; pipeline not tested for this release</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="10">
            <div class="question-header">
              <span class="question-number">11</span>
              <div>
                <h3>Rollback Plan</h3>
                <p>Rollback plan documented?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="10" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; step-by-step rollback procedure documented</span>
              </button>
              <button class="option-row" data-question="10" data-value="2" data-label="Partial" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Partial &mdash; general approach known but not written down</span>
              </button>
              <button class="option-row" data-question="10" data-value="0" data-label="No" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">No &mdash; no rollback plan exists</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="11">
            <div class="question-header">
              <span class="question-number">12</span>
              <div>
                <h3>Database Migrations</h3>
                <p>Database migrations tested?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="11" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; migrations tested on staging with production-like data</span>
              </button>
              <button class="option-row" data-question="11" data-value="2" data-label="N/A" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">N/A &mdash; no database migrations in this release</span>
              </button>
              <button class="option-row" data-question="11" data-value="0" data-label="Not tested" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Not tested &mdash; migrations exist but have not been verified</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="12">
            <div class="question-header">
              <span class="question-number">13</span>
              <div>
                <h3>Monitoring &amp; Alerting</h3>
                <p>Monitoring and alerting configured?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="12" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; dashboards, alerts, and on-call routes in place</span>
              </button>
              <button class="option-row" data-question="12" data-value="2" data-label="Partial" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Partial &mdash; basic monitoring exists, some gaps</span>
              </button>
              <button class="option-row" data-question="12" data-value="0" data-label="No" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">No &mdash; no monitoring or alerting set up</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Category 3: Documentation -->
        <div class="category-panel" data-category-panel="3">
          <div class="category-heading">
            <div class="category-icon category-icon--docs">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <h2>Documentation</h2>
              <p>Ensure all docs are current for the release.</p>
            </div>
          </div>

          <div class="question-card card" data-question="13">
            <div class="question-header">
              <span class="question-number">14</span>
              <div>
                <h3>Release Notes</h3>
                <p>Release notes written?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="13" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; complete release notes ready for distribution</span>
              </button>
              <button class="option-row" data-question="13" data-value="2" data-label="Draft" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Draft &mdash; notes started but not finalized</span>
              </button>
              <button class="option-row" data-question="13" data-value="0" data-label="No" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">No &mdash; release notes have not been written</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="14">
            <div class="question-header">
              <span class="question-number">15</span>
              <div>
                <h3>API Documentation</h3>
                <p>API docs updated?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="14" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; all API changes documented</span>
              </button>
              <button class="option-row" data-question="14" data-value="2" data-label="N/A" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">N/A &mdash; no API changes in this release</span>
              </button>
              <button class="option-row" data-question="14" data-value="0" data-label="No" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">No &mdash; API changes exist but docs not updated</span>
              </button>
            </div>
          </div>

          <div class="question-card card" data-question="15">
            <div class="question-header">
              <span class="question-number">16</span>
              <div>
                <h3>Internal Runbook</h3>
                <p>Internal runbook updated?</p>
              </div>
            </div>
            <div class="options-list">
              <button class="option-row" data-question="15" data-value="3" data-label="Yes" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Yes &mdash; runbook reflects all operational changes</span>
              </button>
              <button class="option-row" data-question="15" data-value="2" data-label="Partial" type="button">
                <span class="option-indicator"></span>
                <span class="option-text">Partial &mdash; some sections updated, others pending</span>
              </button>
              <button class="option-row" data-question="15" data-value="0" data-label="No" type="button">
