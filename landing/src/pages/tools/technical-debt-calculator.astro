---
import Base from '../../layouts/Base.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Technical Debt Calculator',
    description: 'Assess your codebase health in 2 minutes. Get a debt score, estimated cost, and a prioritized action plan.',
    url: 'https://bugreel.io/tools/technical-debt-calculator',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    browserRequirements: 'Requires JavaScript',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    creator: {
      '@type': 'Organization',
      name: 'BugReel',
      url: 'https://bugreel.io',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bugreel.io' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://bugreel.io/tools' },
      { '@type': 'ListItem', position: 3, name: 'Technical Debt Calculator', item: 'https://bugreel.io/tools/technical-debt-calculator' },
    ],
  },
];
---

<Base
  title="Technical Debt Calculator — Codebase Health Assessment | BugReel"
  description="Assess your codebase health in 2 minutes. Answer 10 questions, get a debt score, estimated annual cost, and a prioritized action plan. Free, no signup required."
  schema={schema}
>
  <!-- Breadcrumb -->
  <div class="page-header section-sm">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/tools">Tools</a>
        <span aria-hidden="true">/</span>
        <span>Technical Debt Calculator</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <span class="badge badge-success">Free &middot; No Signup</span>
        <h1>Technical Debt Calculator</h1>
        <p class="hero-subtitle">Assess your codebase health in 2 minutes. Get a debt score, estimated cost, and a prioritized action plan.</p>
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <section class="tool-section">
    <div class="container">

      <!-- Progress -->
      <div class="progress-bar" id="progress-bar">
        <div class="progress-track">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
        <span class="progress-label" id="progress-label">Question 0 of 10</span>
      </div>

      <!-- Questions -->
      <div class="questions-container" id="questions-container">

        <!-- Q1: Codebase Age -->
        <div class="question-card card" data-question="0">
          <div class="question-header">
            <span class="question-number">1</span>
            <div>
              <h3>Codebase Age</h3>
              <p>How old is the core codebase?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="0" data-value="0" data-label="Less than 1 year" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Less than 1 year</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="0" data-value="1" data-label="1-3 years" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">1&ndash;3 years</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="0" data-value="2" data-label="3-7 years" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">3&ndash;7 years</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="0" data-value="3" data-label="7+ years" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">7+ years</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q2: Test Coverage -->
        <div class="question-card card" data-question="1">
          <div class="question-header">
            <span class="question-number">2</span>
            <div>
              <h3>Test Coverage</h3>
              <p>What's your automated test coverage?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="1" data-value="0" data-label=">80%" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">&gt;80%</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="1" data-value="1" data-label="50-80%" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">50&ndash;80%</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="1" data-value="2" data-label="20-50%" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">20&ndash;50%</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="1" data-value="3" data-label="<20% or unknown" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">&lt;20% or unknown</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q3: Deployment Frequency -->
        <div class="question-card card" data-question="2">
          <div class="question-header">
            <span class="question-number">3</span>
            <div>
              <h3>Deployment Frequency</h3>
              <p>How often do you deploy to production?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="2" data-value="0" data-label="Multiple times/day" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Multiple times per day</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="2" data-value="1" data-label="Weekly" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Weekly</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="2" data-value="2" data-label="Monthly" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Monthly</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="2" data-value="3" data-label="Quarterly or less" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Quarterly or less</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q4: Bug Rate -->
        <div class="question-card card" data-question="3">
          <div class="question-header">
            <span class="question-number">4</span>
            <div>
              <h3>Bug Rate</h3>
              <p>How many production bugs per month?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="3" data-value="0" data-label="<5 bugs/month" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Fewer than 5</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="3" data-value="1" data-label="5-15 bugs/month" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">5&ndash;15</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="3" data-value="2" data-label="15-30 bugs/month" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">15&ndash;30</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="3" data-value="3" data-label="30+ bugs/month" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">30+</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q5: Onboarding Time -->
        <div class="question-card card" data-question="4">
          <div class="question-header">
            <span class="question-number">5</span>
            <div>
              <h3>Onboarding Time</h3>
              <p>How long for a new developer to make their first meaningful commit?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="4" data-value="0" data-label="<1 week" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Less than 1 week</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="4" data-value="1" data-label="1-2 weeks" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">1&ndash;2 weeks</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="4" data-value="2" data-label="2-4 weeks" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">2&ndash;4 weeks</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="4" data-value="3" data-label="1+ month" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">More than 1 month</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q6: Dependency Health -->
        <div class="question-card card" data-question="5">
          <div class="question-header">
            <span class="question-number">6</span>
            <div>
              <h3>Dependency Health</h3>
              <p>How current are your dependencies?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="5" data-value="0" data-label="All up to date" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">All up to date</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="5" data-value="1" data-label="Minor versions behind" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Minor versions behind</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="5" data-value="2" data-label="Major versions behind" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Major versions behind</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="5" data-value="3" data-label="EOL dependencies" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">End-of-life dependencies</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q7: Documentation -->
        <div class="question-card card" data-question="6">
          <div class="question-header">
            <span class="question-number">7</span>
            <div>
              <h3>Documentation</h3>
              <p>How is your technical documentation?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="6" data-value="0" data-label="Comprehensive and current" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Comprehensive and current</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="6" data-value="1" data-label="Exists but outdated" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Exists but outdated</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="6" data-value="2" data-label="Minimal" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Minimal</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="6" data-value="3" data-label="None" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">None</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q8: Code Duplication -->
        <div class="question-card card" data-question="7">
          <div class="question-header">
            <span class="question-number">8</span>
            <div>
              <h3>Code Duplication</h3>
              <p>How much copy-paste code exists?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="7" data-value="0" data-label="Minimal, DRY codebase" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Minimal, DRY codebase</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="7" data-value="1" data-label="Some duplication" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Some duplication</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="7" data-value="2" data-label="Significant duplication" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Significant duplication</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="7" data-value="3" data-label="Rampant, no abstractions" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Rampant, no abstractions</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q9: Build Time -->
        <div class="question-card card" data-question="8">
          <div class="question-header">
            <span class="question-number">9</span>
            <div>
              <h3>Build Time</h3>
              <p>How long does a full build/CI take?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="8" data-value="0" data-label="<5 minutes" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Less than 5 minutes</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="8" data-value="1" data-label="5-15 minutes" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">5&ndash;15 minutes</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="8" data-value="2" data-label="15-30 minutes" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">15&ndash;30 minutes</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="8" data-value="3" data-label="30+ minutes" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">30+ minutes</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

        <!-- Q10: Developer Satisfaction -->
        <div class="question-card card" data-question="9">
          <div class="question-header">
            <span class="question-number">10</span>
            <div>
              <h3>Developer Satisfaction</h3>
              <p>How does the team feel about the codebase?</p>
            </div>
          </div>
          <div class="options-list">
            <button class="option-row" data-question="9" data-value="0" data-label="Love working in it" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Love working in it</span>
              <span class="option-pts">0 pts</span>
            </button>
            <button class="option-row" data-question="9" data-value="1" data-label="It's fine" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">It's fine</span>
              <span class="option-pts">1 pt</span>
            </button>
            <button class="option-row" data-question="9" data-value="2" data-label="Frustrating" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Frustrating</span>
              <span class="option-pts">2 pts</span>
            </button>
            <button class="option-row" data-question="9" data-value="3" data-label="Actively looking for new jobs" type="button">
              <span class="option-indicator"></span>
              <span class="option-text">Actively looking for new jobs</span>
              <span class="option-pts">3 pts</span>
            </button>
          </div>
        </div>

      </div>

      <!-- Result Panel -->
      <div class="result-panel" id="result-panel" hidden>
        <div class="result-card" id="result-card">

          <!-- Score Header -->
          <div class="result-header">
            <div class="result-severity">
              <span class="severity-dot-lg" id="result-dot"></span>
              <div>
                <span class="result-level" id="result-category-text">Healthy</span>
                <span class="result-priority" id="result-summary-text">Your codebase is in good shape</span>
              </div>
            </div>
            <div class="result-score">
              <span class="result-score-number" id="result-score-number">0</span>
              <span class="result-score-total">/30</span>
            </div>
          </div>

          <!-- Debt Gauge -->
          <div class="gauge-section" id="gauge-section">
            <div class="gauge-container">
              <svg class="gauge-svg" viewBox="0 0 280 160" aria-hidden="true">
                <path d="M 30 140 A 110 110 0 0 1 250 140" fill="none" stroke="var(--color-border)" stroke-width="18" stroke-linecap="round"/>
                <path id="gauge-arc" d="M 30 140 A 110 110 0 0 1 250 140" fill="none" stroke="url(#gauge-gradient)" stroke-width="18" stroke-linecap="round" stroke-dasharray="345.58" stroke-dashoffset="345.58"/>
                <defs>
                  <linearGradient id="gauge-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#22c55e"/>
                    <stop offset="33%" stop-color="#f59e0b"/>
                    <stop offset="66%" stop-color="#f97316"/>
                    <stop offset="100%" stop-color="#ef4444"/>
                  </linearGradient>
                </defs>
              </svg>
              <div class="gauge-labels">
                <span class="gauge-label-start">0</span>
                <span class="gauge-label-end">30</span>
              </div>
            </div>
          </div>

          <!-- Score Breakdown -->
          <div class="result-breakdown" id="result-breakdown">
            <!-- Filled by JS -->
          </div>

          <!-- Cost Estimation -->
          <div class="cost-section" id="cost-section">
            <h3 class="cost-title">Estimated Annual Cost of Debt</h3>
            <p class="cost-subtitle">Technical debt slows your team down. Estimate the productivity loss.</p>

            <div class="cost-sliders">
              <div class="slider-group">
                <div class="slider-header">
                  <label for="team-size-slider">Team size</label>
                  <span class="slider-value" id="team-size-value">8</span>
                </div>
                <input type="range" id="team-size-slider" min="1" max="50" value="8" class="range-slider">
                <div class="slider-range">
                  <span>1</span>
                  <span>50</span>
                </div>
              </div>

              <div class="slider-group">
                <div class="slider-header">
                  <label for="salary-slider">Average salary</label>
                  <span class="slider-value" id="salary-value">$100,000</span>
                </div>
                <input type="range" id="salary-slider" min="50000" max="200000" step="5000" value="100000" class="range-slider">
                <div class="slider-range">
                  <span>$50K</span>
                  <span>$200K</span>
                </div>
              </div>
            </div>

            <div class="cost-result">
              <p class="cost-label">Your technical debt costs approximately</p>
              <p class="cost-amount" id="cost-amount">$0</p>
              <p class="cost-period">per year in lost productivity</p>
            </div>
          </div>

          <!-- Action Plan -->
          <div class="action-plan" id="action-plan">
            <h3 class="action-plan-title">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Prioritized Action Plan
            </h3>
            <div id="action-items">
              <!-- Filled by JS -->
            </div>
          </div>

          <!-- Actions -->
          <div class="result-actions">
            <button class="btn btn-primary" id="copy-assessment-btn" type="button">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="5" y="5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3 11V3.5A.5.5 0 013.5 3H11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <span id="copy-assessment-text">Copy Assessment</span>
            </button>
            <button class="btn btn-secondary" id="reset-btn" type="button">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M2.5 8a5.5 5.5 0 019.3-3.95" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M13.5 8a5.5 5.5 0 01-9.3 3.95" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M12 2v2.5h-2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M4 13.5V11h2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Reset
            </button>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- What is Technical Debt -->
  <section class="section-sm explanation-section">
    <div class="container">
      <h2 class="explanation-title">What is Technical Debt?</h2>
      <p class="explanation-subtitle">The hidden tax on every feature you ship.</p>
      <div class="explanation-content">
        <div class="explanation-card card">
          <div class="explanation-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p>Technical debt is the implied cost of future rework caused by choosing a quick solution now instead of a better approach that would take longer. Like financial debt, it accumulates interest: the longer you leave it, the more expensive it becomes to fix.</p>
          <p style="margin-top: 16px;">It shows up as slow builds, brittle tests, spaghetti code, outdated dependencies, and developers who dread touching certain parts of the system. Left unchecked, it slows feature delivery, increases bug rates, and drives away your best engineers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tips -->
  <section class="section-sm tips-section">
    <div class="container">
      <h2 class="tips-title">3 Strategies to Reduce Technical Debt</h2>
      <div class="tips-grid">
        <div class="tip-card card">
          <div class="tip-number">1</div>
          <h3>Dedicate 20% of each sprint</h3>
