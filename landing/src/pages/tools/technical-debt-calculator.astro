    8: {
      title: 'Speed up your build pipeline',
      text: 'Slow builds kill developer flow and delay feedback. Parallelize test suites, cache dependencies, use incremental builds, and consider splitting your monolith into smaller build targets.',
    },
    9: {
      title: 'Improve developer experience',
      text: 'Developer frustration leads to turnover, which is the most expensive form of tech debt. Run an anonymous survey, fix the top 3 pain points, and allocate dedicated time for DX improvements.',
    },
  };

  // --- DOM ---
  const progressFill = document.getElementById('progress-fill') as HTMLDivElement;
  const progressLabel = document.getElementById('progress-label') as HTMLSpanElement;
  const questionsContainer = document.getElementById('questions-container')!;
  const resultPanel = document.getElementById('result-panel') as HTMLDivElement;
  const resultCard = document.getElementById('result-card') as HTMLDivElement;
  const resultDot = document.getElementById('result-dot') as HTMLSpanElement;
  const resultCategoryText = document.getElementById('result-category-text')!;
  const resultSummaryText = document.getElementById('result-summary-text')!;
  const resultScoreNumber = document.getElementById('result-score-number')!;
  const resultBreakdown = document.getElementById('result-breakdown')!;
  const gaugeArc = document.getElementById('gauge-arc') as SVGPathElement;
  const costSection = document.getElementById('cost-section')!;
  const costAmount = document.getElementById('cost-amount')!;
  const teamSizeSlider = document.getElementById('team-size-slider') as HTMLInputElement;
  const teamSizeValue = document.getElementById('team-size-value')!;
  const salarySlider = document.getElementById('salary-slider') as HTMLInputElement;
  const salaryValue = document.getElementById('salary-value')!;
  const actionItems = document.getElementById('action-items')!;
  const copyAssessmentBtn = document.getElementById('copy-assessment-btn')!;
  const copyAssessmentText = document.getElementById('copy-assessment-text')!;
  const resetBtn = document.getElementById('reset-btn')!;

  const allOptionButtons = questionsContainer.querySelectorAll('.option-row') as NodeListOf<HTMLButtonElement>;
  const allQuestionCards = questionsContainer.querySelectorAll('.question-card') as NodeListOf<HTMLDivElement>;

  // --- Scoring ---
  interface DebtResult {
    category: string;
    categoryLabel: string;
    summary: string;
    colorClass: string;
    dotClass: string;
  }

  function calcResult(total: number): DebtResult {
    if (total <= 7) {
      return {
        category: 'healthy',
        categoryLabel: 'Healthy',
        summary: 'Your codebase is in good shape',
        colorClass: 'debt-healthy',
        dotClass: 'dot-healthy',
      };
    } else if (total <= 14) {
      return {
        category: 'moderate',
        categoryLabel: 'Moderate',
        summary: 'Some debt accumulating, address proactively',
        colorClass: 'debt-moderate',
        dotClass: 'dot-moderate',
      };
    } else if (total <= 21) {
      return {
        category: 'high',
        categoryLabel: 'High',
        summary: 'Significant debt, plan remediation sprints',
        colorClass: 'debt-high',
        dotClass: 'dot-high',
      };
    } else {
      return {
        category: 'critical',
        categoryLabel: 'Critical',
        summary: 'Codebase is a liability, urgent action needed',
        colorClass: 'debt-critical',
        dotClass: 'dot-critical',
      };
    }
  }

  // --- Cost calculation ---
  // The overhead factor scales with debt: higher debt = higher % of time wasted
  function calcAnnualCost(total: number, teamSize: number, avgSalary: number): number {
    // Debt percentage: score / 30 mapped to a realistic overhead range
    // 0 debt = 5% overhead (baseline), 30 debt = 65% overhead
    const minOverhead = 0.05;
    const maxOverhead = 0.65;
    const debtPct = total / 30;
    const overhead = minOverhead + (maxOverhead - minOverhead) * debtPct;
    return Math.round(teamSize * avgSalary * overhead);
  }

  function formatCurrency(amount: number): string {
    if (amount >= 1000000) {
      return '$' + (amount / 1000000).toFixed(1) + 'M';
    } else if (amount >= 1000) {
      return '$' + Math.round(amount / 1000).toLocaleString() + 'K';
    }
    return '$' + amount.toLocaleString();
  }

  function updateCost() {
    const total = answers.reduce((sum, a) => sum! + (a ?? 0), 0) as number;
    const teamSize = parseInt(teamSizeSlider.value);
    const salary = parseInt(salarySlider.value);
    const cost = calcAnnualCost(total, teamSize, salary);
    costAmount.textContent = formatCurrency(cost);
    teamSizeValue.textContent = String(teamSize);
    salaryValue.textContent = '$' + (salary / 1000).toFixed(0) + ',000';
  }

  // --- Gauge ---
  // Total arc length for the semicircle path
  const GAUGE_ARC_LENGTH = 345.58;

  function updateGauge(total: number) {
    const pct = total / 30;
    const offset = GAUGE_ARC_LENGTH * (1 - pct);
    gaugeArc.style.transition = 'stroke-dashoffset 1s ease';
    gaugeArc.style.strokeDashoffset = String(offset);
  }

  // --- Action plan ---
  function buildActionPlan(): void {
    // Find the 3 worst-scoring questions (highest score first)
    const indexed = answers.map((val, idx) => ({ idx, val: val ?? 0 }));
    indexed.sort((a, b) => b.val - a.val);

    // Take top 3 (skip any with 0 score)
    const worst = indexed.filter(item => item.val > 0).slice(0, 3);

    if (worst.length === 0) {
      actionItems.innerHTML = '<p style="font-size: 0.9375rem; color: var(--color-text-muted);">No action items needed. Your codebase scored perfectly across all dimensions.</p>';
      return;
    }

    let html = '';
    worst.forEach((item, rank) => {
      const rec = questionRecommendations[item.idx];
      html += `
        <div class="action-item">
          <span class="action-rank rank-${rank + 1}">${rank + 1}</span>
          <div class="action-body">
            <h4>${rec.title}</h4>
            <p>${rec.text}</p>
          </div>
        </div>
      `;
    });
    actionItems.innerHTML = html;
  }

  // --- Progress ---
  function updateProgress() {
    const answered = answers.filter(a => a !== null).length;
    const pct = (answered / TOTAL_QUESTIONS) * 100;
    progressFill.style.width = pct + '%';
    progressLabel.textContent = `Question ${answered} of ${TOTAL_QUESTIONS}`;
  }

  // --- Option Click ---
  function handleOptionClick(btn: HTMLButtonElement) {
    const qIdx = parseInt(btn.getAttribute('data-question')!);
    const value = parseInt(btn.getAttribute('data-value')!);
    const label = btn.getAttribute('data-label')!;

    // Deselect siblings
    const siblings = questionsContainer.querySelectorAll(`.option-row[data-question="${qIdx}"]`);
    siblings.forEach(s => s.classList.remove('selected'));

    // Select this
    btn.classList.add('selected');

    // Store answer
    answers[qIdx] = value;
    answerLabels[qIdx] = label;

    // Mark card as answered
    allQuestionCards[qIdx].classList.add('answered');

    updateProgress();

    // Check if all answered
    const allAnswered = answers.every(a => a !== null);
    if (allAnswered) {
      showResult();
    }
  }

  allOptionButtons.forEach(btn => {
    btn.addEventListener('click', () => handleOptionClick(btn));
  });

  // --- Show Result ---
  function showResult() {
    const total = answers.reduce((sum, a) => sum! + (a ?? 0), 0) as number;
    const result = calcResult(total);

    // Update result card
    resultCard.className = 'result-card ' + result.colorClass;
    resultDot.className = 'severity-dot-lg ' + result.dotClass;
    resultCategoryText.textContent = result.categoryLabel;
    resultSummaryText.textContent = result.summary;
    resultScoreNumber.textContent = String(total);

    // Gauge
    updateGauge(total);

    // Breakdown
    let breakdownHtml = '';
    for (let i = 0; i < TOTAL_QUESTIONS; i++) {
      breakdownHtml += `
        <div class="breakdown-row">
          <span class="breakdown-label">${questionNames[i]}</span>
          <div class="breakdown-value">
            <span class="breakdown-answer">${answerLabels[i] || '\u2014'}</span>
            <span class="breakdown-pts">${answers[i] ?? 0}/3</span>
          </div>
        </div>
      `;
    }
    resultBreakdown.innerHTML = breakdownHtml;

    // Cost
    updateCost();

    // Action plan
    buildActionPlan();

    // Show
    resultPanel.hidden = false;

    // Smooth scroll to result
    setTimeout(() => {
      resultPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  }

  // --- Slider events ---
  teamSizeSlider.addEventListener('input', updateCost);
  salarySlider.addEventListener('input', updateCost);

  // --- Copy Assessment ---
  function buildAssessmentText(): string {
    const total = answers.reduce((sum, a) => sum! + (a ?? 0), 0) as number;
    const result = calcResult(total);
    const teamSize = parseInt(teamSizeSlider.value);
    const salary = parseInt(salarySlider.value);
    const cost = calcAnnualCost(total, teamSize, salary);

    let text = `Technical Debt Assessment\n`;
    text += `========================\n\n`;
    text += `Debt Score: ${total}/30 (${result.categoryLabel})\n`;
    text += `${result.summary}\n\n`;
    text += `Breakdown:\n`;
    for (let i = 0; i < TOTAL_QUESTIONS; i++) {
      text += `  ${questionNames[i]}: ${answerLabels[i] || '\u2014'} (${answers[i] ?? 0}/3)\n`;
    }
    text += `\nEstimated Annual Cost: ${formatCurrency(cost)}\n`;
    text += `  Team size: ${teamSize} | Avg salary: $${(salary / 1000).toFixed(0)}K\n\n`;

    // Top priorities
    const indexed = answers.map((val, idx) => ({ idx, val: val ?? 0 }));
    indexed.sort((a, b) => b.val - a.val);
    const worst = indexed.filter(item => item.val > 0).slice(0, 3);
    if (worst.length > 0) {
      text += `Top Priorities:\n`;
      worst.forEach((item, rank) => {
        const rec = questionRecommendations[item.idx];
        text += `  ${rank + 1}. ${rec.title}\n`;
      });
    }

    text += `\nGenerated by BugReel Technical Debt Calculator\nhttps://bugreel.io/tools/technical-debt-calculator`;
    return text;
  }

  copyAssessmentBtn.addEventListener('click', async () => {
    const text = buildAssessmentText();
    try {
      await navigator.clipboard.writeText(text);
      copyAssessmentBtn.classList.add('copied');
      copyAssessmentText.textContent = 'Copied!';
      setTimeout(() => {
        copyAssessmentBtn.classList.remove('copied');
        copyAssessmentText.textContent = 'Copy Assessment';
      }, 2000);
    } catch {
      // Fallback
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
      copyAssessmentBtn.classList.add('copied');
      copyAssessmentText.textContent = 'Copied!';
      setTimeout(() => {
        copyAssessmentBtn.classList.remove('copied');
        copyAssessmentText.textContent = 'Copy Assessment';
      }, 2000);
    }
  });

  // --- Reset ---
  resetBtn.addEventListener('click', () => {
    // Clear answers
    for (let i = 0; i < TOTAL_QUESTIONS; i++) {
      answers[i] = null;
      answerLabels[i] = null;
    }

    // Deselect all options
    allOptionButtons.forEach(btn => btn.classList.remove('selected'));

    // Remove answered state from cards
    allQuestionCards.forEach(card => card.classList.remove('answered'));

    // Hide result
    resultPanel.hidden = true;

    // Reset gauge
    gaugeArc.style.transition = 'none';
    gaugeArc.style.strokeDashoffset = String(GAUGE_ARC_LENGTH);

    // Reset sliders
    teamSizeSlider.value = '8';
    salarySlider.value = '100000';

    // Reset progress
    updateProgress();

    // Scroll to top
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // --- Initial state ---
  updateProgress();
</script>
