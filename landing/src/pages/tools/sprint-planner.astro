  // --- Slider track fill ---
  function updateSliderFill(slider: HTMLInputElement): void {
    const min = parseFloat(slider.min);
    const max = parseFloat(slider.max);
    const val = parseFloat(slider.value);
    const pct = ((val - min) / (max - min)) * 100;
    const color = 'rgba(99, 102, 241, 0.5)';
    slider.style.background = `linear-gradient(to right, ${color} 0%, ${color} ${pct}%, var(--color-border) ${pct}%, var(--color-border) 100%)`;
  }

  // --- Core Calculation ---
  function calculate(): void {
    const teamMembers = parseInt(teamMembersSlider.value);
    const sprintDays = parseInt(sprintLengthSelect.value);
    const hoursPerDay = parseInt(hoursPerDaySlider.value);
    const daysOff = parseInt(daysOffSlider.value);
    const carryOver = parseInt(carryOverSlider.value);
    const riskBufferPct = parseFloat(riskBufferSelect.value);
    const useEstimate = noHistoryToggle.checked;

    // Update value displays
    teamMembersValueEl.textContent = String(teamMembers);
    hoursPerDayValueEl.innerHTML = hoursPerDay + '<small>hrs</small>';
    daysOffValueEl.textContent = String(daysOff);
    carryOverValueEl.innerHTML = carryOver + '<small>pts</small>';

    // Update slider fills
    updateSliderFill(teamMembersSlider);
    updateSliderFill(hoursPerDaySlider);
    updateSliderFill(daysOffSlider);
    updateSliderFill(carryOverSlider);

    // --- Capacity ---
    const totalPersonDays = (teamMembers * sprintDays) - daysOff;
    const effectivePersonDays = Math.max(totalPersonDays, 0);
    const totalAvailableHours = effectivePersonDays * hoursPerDay;
    // Effective hours account for overhead (standup, retro, planning ~15% of working hours)
    const overheadFactor = 0.85;
    const effectiveHours = Math.round(totalAvailableHours * overheadFactor);

    // --- Velocity ---
    let avgVelocity: number;
    let minVel: number;
    let maxVel: number;
    let velocityVariance: number;
    let trend: 'up' | 'down' | 'stable';

    if (useEstimate) {
      // Estimate based on team size and sprint length
      avgVelocity = Math.round(teamMembers * sprintDays * DEFAULT_SP_PER_PERSON_PER_DAY);
      minVel = avgVelocity;
      maxVel = avgVelocity;
      velocityVariance = 0.3; // high uncertainty
      trend = 'stable';
    } else {
      const s1 = parseInt(sprint1Input.value) || 0;
      const s2 = parseInt(sprint2Input.value) || 0;
      const s3 = parseInt(sprint3Input.value) || 0;

      avgVelocity = Math.round((s1 + s2 + s3) / 3);
      minVel = Math.min(s1, s2, s3);
      maxVel = Math.max(s1, s2, s3);

      // Variance as coefficient of variation
      const mean = (s1 + s2 + s3) / 3;
      if (mean > 0) {
        const stdDev = Math.sqrt(((s1 - mean) ** 2 + (s2 - mean) ** 2 + (s3 - mean) ** 2) / 3);
        velocityVariance = stdDev / mean;
      } else {
        velocityVariance = 0;
      }

      // Trend: compare most recent (s1) to oldest (s3)
      if (s1 > s3 * 1.05) {
        trend = 'up';
      } else if (s1 < s3 * 0.95) {
        trend = 'down';
      } else {
        trend = 'stable';
      }
    }

    // --- Scale velocity by capacity ratio ---
    // If team has less capacity this sprint (PTO etc), scale velocity
    const normalCapacityDays = teamMembers * sprintDays;
    const capacityRatio = normalCapacityDays > 0 ? effectivePersonDays / normalCapacityDays : 1;
    const scaledVelocity = Math.round(avgVelocity * capacityRatio);

    // SP capacity estimate
    const spCapacity = scaledVelocity;

    // --- Commitment ---
    const bufferPoints = Math.round(spCapacity * riskBufferPct);
    const rawCommitment = spCapacity - carryOver - bufferPoints;
    const commitment = Math.max(rawCommitment, 0);

    // --- Confidence ---
    // Low variance + buffer = high confidence
    let confidence: number;
    if (useEstimate) {
      confidence = 50; // no data = low confidence
    } else {
      // Base confidence from variance (low variance = high confidence)
      const varianceScore = Math.max(0, 1 - velocityVariance * 3); // 0 to 1
      // Buffer bonus
      const bufferBonus = riskBufferPct * 0.5; // 0 to 0.15
      confidence = Math.min(95, Math.round((varianceScore * 0.7 + bufferBonus + 0.15) * 100));
      confidence = Math.max(40, confidence);
    }

    // --- Update DOM ---

    // Commitment
    commitmentNumberEl.textContent = String(commitment);
    breakdownCapacityEl.textContent = String(spCapacity);
    breakdownCarryoverEl.textContent = String(carryOver);
    breakdownBufferEl.textContent = String(bufferPoints);
    breakdownCommitEl.textContent = String(commitment);

    // Confidence
    let confidenceLabel: string;
    if (confidence >= 80) {
      confidenceLabel = 'High confidence';
    } else if (confidence >= 60) {
      confidenceLabel = 'Moderate confidence';
    } else {
      confidenceLabel = 'Low confidence';
    }
    if (useEstimate) {
      confidenceTextEl.textContent = confidence + '% confidence -- no historical data, using estimate';
    } else {
      confidenceTextEl.textContent = confidence + '% confidence based on velocity variance';
    }

    // Stacked bar
    const totalBar = spCapacity > 0 ? spCapacity : 1;
    const committedPct = Math.max((commitment / totalBar) * 100, 0);
    const bufferPct = Math.max((bufferPoints / totalBar) * 100, 0);
    const carryoverPct = Math.max((carryOver / totalBar) * 100, 0);

    // Normalize to 100%
    const sumPct = committedPct + bufferPct + carryoverPct;
    const norm = sumPct > 0 ? 100 / sumPct : 0;

    barCommittedEl.style.width = Math.max(committedPct * norm, commitment > 0 ? 5 : 0) + '%';
    barBufferEl.style.width = Math.max(bufferPct * norm, bufferPoints > 0 ? 3 : 0) + '%';
    barCarryoverEl.style.width = Math.max(carryoverPct * norm, carryOver > 0 ? 3 : 0) + '%';

    barCommittedLabelEl.textContent = commitment + ' pts';
    barBufferLabelEl.textContent = bufferPoints > 0 ? String(bufferPoints) : '';
    barCarryoverLabelEl.textContent = carryOver > 0 ? String(carryOver) : '';

    // Capacity metrics
    metricTotalHoursEl.textContent = String(totalAvailableHours);
    metricEffectiveHoursEl.textContent = String(effectiveHours);
    metricSpCapacityEl.textContent = String(spCapacity);

    // Velocity analysis
    velAverageEl.textContent = String(avgVelocity);

    // Trend
    trendArrowEl.classList.remove('trend-up', 'trend-down', 'trend-stable');
    trendTextEl.classList.remove('trend-up', 'trend-down', 'trend-stable');

    if (useEstimate) {
      trendArrowEl.classList.add('trend-stable');
      trendArrowEl.innerHTML = '<line x1="3" y1="9" x2="15" y2="9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>';
      trendTextEl.textContent = 'N/A';
      trendTextEl.classList.add('trend-stable');
    } else if (trend === 'up') {
      trendArrowEl.classList.add('trend-up');
      trendArrowEl.innerHTML = '<path d="M9 14V4M9 4l4 4M9 4L5 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
      trendTextEl.textContent = 'Improving';
      trendTextEl.classList.add('trend-up');
    } else if (trend === 'down') {
      trendArrowEl.classList.add('trend-down');
      trendArrowEl.innerHTML = '<path d="M9 4V14M9 14l4-4M9 14L5 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
      trendTextEl.textContent = 'Declining';
      trendTextEl.classList.add('trend-down');
    } else {
      trendArrowEl.classList.add('trend-stable');
      trendArrowEl.innerHTML = '<path d="M3 9h12M12 6l3 3-3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>';
      trendTextEl.textContent = 'Stable';
      trendTextEl.classList.add('trend-stable');
    }

    // Velocity range
    if (useEstimate) {
      velRangeEl.innerHTML = 'Estimated';
    } else {
      velRangeEl.innerHTML = minVel + ' &ndash; ' + maxVel;
    }
  }

  // --- Toggle velocity history ---
  noHistoryToggle.addEventListener('change', function () {
    if (noHistoryToggle.checked) {
      velocityInputsDiv.style.opacity = '0.3';
      velocityInputsDiv.style.pointerEvents = 'none';
    } else {
      velocityInputsDiv.style.opacity = '1';
      velocityInputsDiv.style.pointerEvents = 'auto';
    }
    calculate();
  });

  // --- Event listeners ---
  const allSliders = [teamMembersSlider, hoursPerDaySlider, daysOffSlider, carryOverSlider];
  allSliders.forEach(function (s) { s.addEventListener('input', calculate); });

  const allSelects = [sprintLengthSelect, riskBufferSelect];
  allSelects.forEach(function (s) { s.addEventListener('change', calculate); });

  const allInputs = [sprint1Input, sprint2Input, sprint3Input];
  allInputs.forEach(function (inp) { inp.addEventListener('input', calculate); });

  // --- Copy Sprint Plan ---
  copyBtn.addEventListener('click', function () {
    const teamMembers = teamMembersSlider.value;
    const sprintDays = sprintLengthSelect.value;
    const sprintWeeks = parseInt(sprintDays) / 5;
    const hoursPerDay = hoursPerDaySlider.value;
    const daysOff = daysOffSlider.value;
    const carryOver = carryOverSlider.value;
    const riskLabel = riskBufferSelect.options[riskBufferSelect.selectedIndex].text;

    const text = [
      '## Sprint Plan',
      '',
      '**Team:** ' + teamMembers + ' members',
      '**Sprint:** ' + sprintWeeks + ' week' + (sprintWeeks > 1 ? 's' : '') + ' (' + sprintDays + ' days)',
      '**Productive hours/day:** ' + hoursPerDay,
      '**Days off:** ' + daysOff,
      '',
      '**Velocity (avg):** ' + velAverageEl.textContent + ' pts/sprint',
      '**Risk buffer:** ' + riskLabel,
      '**Carry-over:** ' + carryOver + ' pts',
      '',
      '### Recommended Commitment: ' + commitmentNumberEl.textContent + ' story points',
      '',
      'Capacity (' + breakdownCapacityEl.textContent + ') - Carry-over (' + breakdownCarryoverEl.textContent + ') - Buffer (' + breakdownBufferEl.textContent + ') = **' + breakdownCommitEl.textContent + ' pts**',
      '',
      confidenceTextEl.textContent,
      '',
      '---',
      '_Generated with [BugReel Sprint Planner](https://bugreel.io/tools/sprint-planner)_',
    ].join('\n');

    navigator.clipboard.writeText(text).then(function () {
      copyBtn.classList.add('copied');
      copyTextEl.textContent = 'Copied!';
      setTimeout(function () {
        copyBtn.classList.remove('copied');
        copyTextEl.textContent = 'Copy Sprint Plan';
      }, 2000);
    });
  });

  // --- Reset ---
  resetBtn.addEventListener('click', function () {
    teamMembersSlider.value = '5';
    sprintLengthSelect.value = '10';
    hoursPerDaySlider.value = '6';
    daysOffSlider.value = '0';
    noHistoryToggle.checked = false;
    velocityInputsDiv.style.opacity = '1';
    velocityInputsDiv.style.pointerEvents = 'auto';
    sprint1Input.value = '34';
    sprint2Input.value = '28';
    sprint3Input.value = '31';
    carryOverSlider.value = '0';
    riskBufferSelect.value = '0.20';
    calculate();
  });

  // --- Explainer Toggle ---
  toggleExplainer.addEventListener('click', function () {
    const expanded = toggleExplainer.getAttribute('aria-expanded') === 'true';
    toggleExplainer.setAttribute('aria-expanded', String(!expanded));
    explainerContent.hidden = expanded;
  });

  // --- Initial ---
  calculate();
</script>
