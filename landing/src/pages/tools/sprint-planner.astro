<script>
  // ===== Sprint Planning Calculator — Client-Side Logic =====

  // --- Default constants ---
  const DEFAULT_SP_PER_PERSON_PER_DAY = 1.2; // estimate when no history

  // --- DOM: Inputs ---
  const teamMembersSlider = document.getElementById('team-members') as HTMLInputElement;
