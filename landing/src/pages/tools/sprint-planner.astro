---
import Base from '../../layouts/Base.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Sprint Planning Calculator',
    description: 'Calculate your team\'s sprint capacity, apply risk buffers, and get a recommended story point commitment with confidence levels. Free sprint planning tool for agile teams.',
    url: 'https://bugreel.io/tools/sprint-planner',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Any',
    browserRequirements: 'Requires JavaScript',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    creator: {
      '@type': 'Organization',
      name: 'BugReel',
      url: 'https://bugreel.io',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://bugreel.io' },
      { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://bugreel.io/tools' },
      { '@type': 'ListItem', position: 3, name: 'Sprint Planning Calculator', item: 'https://bugreel.io/tools/sprint-planner' },
    ],
  },
];
---

<Base
  title="Sprint Planning Calculator — Capacity, Velocity & Risk Buffer | BugReel"
  description="Calculate your team's sprint capacity, apply risk buffers, and get a recommended story point commitment with confidence levels. Free sprint planning tool for agile teams."
  schema={schema}
>
  <!-- Breadcrumb -->
  <div class="page-header section-sm">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/tools">Tools</a>
        <span aria-hidden="true">/</span>
        <span>Sprint Planning Calculator</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <span class="badge badge-accent">Free &middot; No Signup</span>
        <h1>Sprint Planning Calculator</h1>
        <p class="hero-subtitle">Calculate your team's sprint capacity, apply risk buffers, and get a recommended story point commitment with confidence levels.</p>
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <section class="tool-section">
    <div class="container">
      <div class="calc-layout">

        <!-- LEFT: Inputs -->
        <div class="input-panel">

          <!-- Team Capacity -->
          <div class="panel-card">
            <h2 class="panel-title">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="13" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/>
                <path d="M1 17c0-3 2.5-5 6-5s6 2 6 5M9 17c0-3 2.5-5 6-5s4 2 4 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              Team Capacity
            </h2>

            <!-- Team Members -->
            <div class="slider-group">
              <div class="slider-header">
                <label for="team-members" class="slider-label">Team Members</label>
                <span class="slider-value" id="team-members-value">5</span>
              </div>
              <p class="slider-hint">Developers and QA contributing to the sprint</p>
              <input
                type="range"
                id="team-members"
                min="1"
                max="20"
                value="5"
                class="calc-slider"
              />
              <div class="slider-range">
                <span>1</span>
                <span>20</span>
              </div>
            </div>

            <!-- Sprint Length -->
            <div class="field-group">
              <label for="sprint-length" class="field-label">Sprint Length</label>
              <div class="select-wrapper">
                <select id="sprint-length" class="calc-select">
                  <option value="5">1 week (5 days)</option>
                  <option value="10" selected>2 weeks (10 days)</option>
                  <option value="15">3 weeks (15 days)</option>
                </select>
                <svg class="select-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>

            <!-- Working Hours Per Day -->
            <div class="slider-group">
              <div class="slider-header">
                <label for="hours-per-day" class="slider-label">Working Hours Per Day</label>
                <span class="slider-value" id="hours-per-day-value">6<small>hrs</small></span>
              </div>
              <p class="slider-hint">Productive coding time (excludes meetings, admin)</p>
              <input
                type="range"
                id="hours-per-day"
                min="4"
                max="8"
                value="6"
                class="calc-slider"
              />
              <div class="slider-range">
                <span>4 hrs</span>
                <span>8 hrs</span>
              </div>
            </div>

            <!-- Days Off -->
            <div class="slider-group">
              <div class="slider-header">
                <label for="days-off" class="slider-label">Days Off This Sprint</label>
                <span class="slider-value" id="days-off-value">0</span>
              </div>
              <p class="slider-hint">Total team days off (holidays, PTO, sick leave)</p>
              <input
                type="range"
                id="days-off"
                min="0"
                max="20"
                value="0"
                class="calc-slider"
              />
              <div class="slider-range">
                <span>0</span>
                <span>20</span>
              </div>
            </div>
          </div>

          <!-- Velocity History -->
          <div class="panel-card">
            <h2 class="panel-title">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3 17l4-6 4 3 6-10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Velocity History
            </h2>

            <div class="toggle-group">
              <label class="toggle-label">
                <input type="checkbox" id="no-history" class="toggle-input" />
                <span class="toggle-switch"></span>
                <span class="toggle-text">No historical data (use estimate)</span>
              </label>
            </div>

            <div id="velocity-inputs">
              <p class="slider-hint" style="margin-bottom: 16px;">Story points completed in the last 3 sprints</p>
              <div class="velocity-grid">
                <div class="velocity-field">
                  <label for="sprint-1" class="velocity-label">Sprint -1</label>
                  <input type="number" id="sprint-1" min="0" max="200" value="34" class="calc-input" />
                </div>
                <div class="velocity-field">
                  <label for="sprint-2" class="velocity-label">Sprint -2</label>
                  <input type="number" id="sprint-2" min="0" max="200" value="28" class="calc-input" />
                </div>
                <div class="velocity-field">
                  <label for="sprint-3" class="velocity-label">Sprint -3</label>
                  <input type="number" id="sprint-3" min="0" max="200" value="31" class="calc-input" />
                </div>
              </div>
            </div>
          </div>

          <!-- Carry-Over & Risk -->
          <div class="panel-card">
            <h2 class="panel-title">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2l2.09 6.26H18l-4.79 3.48L15.12 18 10 14.27 4.88 18l1.91-6.26L2 8.26h5.91z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Adjustments
            </h2>

            <!-- Carry-Over -->
            <div class="slider-group">
              <div class="slider-header">
                <label for="carry-over" class="slider-label">Carry-Over from Last Sprint</label>
                <span class="slider-value" id="carry-over-value">0<small>pts</small></span>
              </div>
              <p class="slider-hint">Unfinished story points rolling into this sprint</p>
              <input
                type="range"
                id="carry-over"
                min="0"
                max="50"
                value="0"
                class="calc-slider"
              />
              <div class="slider-range">
                <span>0</span>
                <span>50</span>
              </div>
            </div>

            <!-- Risk Buffer -->
            <div class="field-group">
              <label for="risk-buffer" class="field-label">Risk Buffer</label>
              <div class="select-wrapper">
                <select id="risk-buffer" class="calc-select">
                  <option value="0.30">Conservative (30% buffer)</option>
                  <option value="0.20" selected>Moderate (20% buffer)</option>
                  <option value="0.10">Aggressive (10% buffer)</option>
                  <option value="0">None (0% buffer)</option>
                </select>
                <svg class="select-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </div>
        </div>

        <!-- RIGHT: Results -->
        <div class="results-panel">
          <div class="results-sticky">

            <!-- Recommended Commitment -->
            <div class="panel-card commitment-card">
              <h2 class="panel-title">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M10 1l2.39 4.84L18 6.74l-4 3.9.94 5.5L10 13.57l-4.94 2.57.94-5.5-4-3.9 5.61-.9z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Recommended Commitment
              </h2>
              <div class="commitment-hero">
                <span class="commitment-number" id="commitment-number">25</span>
                <span class="commitment-unit">story points</span>
              </div>
              <div class="commitment-breakdown">
                <div class="breakdown-item">
                  <span class="breakdown-label">Capacity</span>
                  <span class="breakdown-value" id="breakdown-capacity">31</span>
                </div>
                <span class="breakdown-op">&minus;</span>
                <div class="breakdown-item">
                  <span class="breakdown-label">Carry-over</span>
                  <span class="breakdown-value breakdown-value--orange" id="breakdown-carryover">0</span>
                </div>
                <span class="breakdown-op">&minus;</span>
                <div class="breakdown-item">
                  <span class="breakdown-label">Buffer</span>
                  <span class="breakdown-value breakdown-value--yellow" id="breakdown-buffer">6</span>
                </div>
                <span class="breakdown-op">=</span>
                <div class="breakdown-item">
                  <span class="breakdown-label">Commit</span>
                  <span class="breakdown-value breakdown-value--green" id="breakdown-commit">25</span>
                </div>
              </div>
              <div class="confidence-row">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M8 5v3.5l2.5 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span id="confidence-text">75% confidence based on velocity variance</span>
              </div>
            </div>

            <!-- Stacked Bar -->
            <div class="panel-card">
              <h2 class="panel-title">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <rect x="2" y="14" width="16" height="3" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <rect x="2" y="9" width="12" height="3" rx="1" stroke="currentColor" stroke-width="1.5"/>
                  <rect x="2" y="4" width="8" height="3" rx="1" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                Sprint Allocation
              </h2>
              <div class="stacked-bar-container">
                <div class="stacked-bar">
                  <div class="stacked-segment stacked-segment--committed" id="bar-committed" style="width: 80%">
                    <span class="stacked-label" id="bar-committed-label">25 pts</span>
                  </div>
                  <div class="stacked-segment stacked-segment--buffer" id="bar-buffer" style="width: 13%">
                    <span class="stacked-label" id="bar-buffer-label">6</span>
                  </div>
                  <div class="stacked-segment stacked-segment--carryover" id="bar-carryover" style="width: 7%">
                    <span class="stacked-label" id="bar-carryover-label">0</span>
                  </div>
                </div>
                <div class="stacked-legend">
                  <div class="legend-item">
                    <span class="legend-dot legend-dot--committed"></span>
                    <span>Committed</span>
                  </div>
                  <div class="legend-item">
                    <span class="legend-dot legend-dot--buffer"></span>
                    <span>Risk Buffer</span>
                  </div>
                  <div class="legend-item">
                    <span class="legend-dot legend-dot--carryover"></span>
                    <span>Carry-over</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Capacity Metrics -->
            <div class="panel-card">
              <h2 class="panel-title">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <circle cx="10" cy="10" r="7.5" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M10 6v4.5l3 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Capacity Metrics
              </h2>
              <div class="metrics-grid">
                <div class="metric-item">
                  <span class="metric-label">Total Available Hours</span>
                  <span class="metric-value" id="metric-total-hours">300</span>
                  <span class="metric-unit">hrs</span>
                </div>
                <div class="metric-item">
                  <span class="metric-label">Effective Hours</span>
                  <span class="metric-value" id="metric-effective-hours">300</span>
                  <span class="metric-unit">hrs</span>
                </div>
                <div class="metric-item">
                  <span class="metric-label">SP Capacity Estimate</span>
                  <span class="metric-value metric-value--accent" id="metric-sp-capacity">31</span>
                  <span class="metric-unit">pts</span>
                </div>
              </div>
            </div>

            <!-- Velocity Analysis -->
            <div class="panel-card">
              <h2 class="panel-title">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M3 17l4-6 4 3 6-10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Velocity Analysis
              </h2>
              <div class="velocity-stats">
                <div class="velocity-stat">
                  <span class="velocity-stat-label">Average Velocity</span>
                  <span class="velocity-stat-value" id="vel-average">31</span>
                  <span class="velocity-stat-unit">pts/sprint</span>
                </div>
                <div class="velocity-stat">
                  <span class="velocity-stat-label">Velocity Trend</span>
                  <span class="velocity-stat-value velocity-trend" id="vel-trend">
                    <svg class="trend-arrow" id="trend-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                      <path d="M9 14V4M9 4l4 4M9 4L5 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span id="trend-text">Improving</span>
                  </span>
                </div>
                <div class="velocity-stat">
                  <span class="velocity-stat-label">Velocity Range</span>
                  <span class="velocity-stat-value" id="vel-range">28 &ndash; 34</span>
                  <span class="velocity-stat-unit">pts/sprint</span>
                </div>
              </div>
            </div>

            <!-- Actions -->
            <div class="results-actions">
              <button class="btn btn-secondary btn-sm" id="copy-btn" type="button">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M11 5V3.5A1.5 1.5 0 009.5 2h-6A1.5 1.5 0 002 3.5v6A1.5 1.5 0 003.5 11H5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                <span id="copy-text">Copy Sprint Plan</span>
              </button>
              <button class="btn btn-secondary btn-sm" id="reset-btn" type="button">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M2 8a6 6 0 1111.47-2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M10 2.5h4v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Reset
              </button>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Best Practices -->
  <section class="section-sm practices-section">
    <div class="container" style="max-width: 900px;">
      <h2 class="practices-heading">Sprint Planning Best Practices</h2>
      <div class="practices-grid">
        <div class="practice-card">
          <div class="practice-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M3 3v18h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M7 16l4-8 4 4 4-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Use Yesterday's Weather</h3>
          <p>Your best predictor of next sprint's velocity is the average of the last 3 sprints. Resist the temptation to plan for your "best case" -- plan for your average.</p>
        </div>
        <div class="practice-card">
          <div class="practice-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2a10 10 0 100 20 10 10 0 000-20z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 8v4l2.5 2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>Always Include a Buffer</h3>
          <p>Unplanned work, production incidents, and scope creep happen every sprint. A 20% risk buffer is not slack -- it is realistic planning that builds trust with stakeholders.</p>
        </div>
        <div class="practice-card">
          <div class="practice-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/>
              <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3>Account for Real Capacity</h3>
          <p>No one codes 8 hours a day. Between standups, reviews, Slack, and context-switching, 5-6 productive hours is realistic. Plan for capacity, not calendar time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Velocity vs Capacity -->
  <section class="section-sm explainer-section">
    <div class="container" style="max-width: 800px;">
      <button class="collapse-toggle" id="toggle-explainer" aria-expanded="false" type="button">
        <svg class="collapse-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Velocity vs Capacity: What's the Difference?
      </button>
      <div class="collapse-content" id="explainer-content" hidden>
        <div class="explainer-body">
          <div class="explainer-col">
            <h3>Velocity</h3>
            <p><strong>What your team actually delivered</strong> in past sprints, measured in story points. It is a backward-looking, empirical metric. Velocity naturally accounts for meetings, interruptions, and other overhead because it reflects real output.</p>
          </div>
          <div class="explainer-col">
            <h3>Capacity</h3>
            <p><strong>How much time your team has available</strong> in the upcoming sprint, measured in hours. It is forward-looking and based on team size, working days, and PTO. Capacity tells you the theoretical maximum -- velocity tells you what is realistic.</p>
          </div>
          <div class="explainer-takeaway">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 1a5 5 0 00-1.8 9.66V12a1 1 0 001 1h1.6a1 1 0 001-1v-1.34A5 5 0 008 1z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M6.5 14.5h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <p><strong>Best approach:</strong> Use velocity as your primary planning input, and capacity as a sanity check. If capacity drops significantly (PTO, holidays), scale velocity proportionally.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-sm cta-bottom">
    <div class="container" style="text-align: center; max-width: 640px;">
      <p class="cta-lead">Deliver sprints on time, every time</p>
      <h2>Catch bugs faster with AI-powered reports</h2>
      <p style="margin: 16px 0 32px; font-size: 1rem;">BugReel turns screen recordings into complete bug reports with steps, screenshots, and severity -- automatically. Fewer bug-related delays, more story points delivered.</p>
      <div class="cta-buttons">
        <a href="https://github.com/BugReel/bugreel" class="btn btn-primary">Try BugReel Free</a>
        <a href="/" class="btn btn-secondary">Learn More</a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ===== Page Header ===== */
  .page-header {
    padding-top: 32px;
    padding-bottom: 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-text);
  }

  .breadcrumb span {
    color: var(--color-text-dim);
  }

  .breadcrumb span:last-child {
    color: var(--color-text);
  }

  /* ===== Hero ===== */
  .hero-section {
    padding: 40px 0 48px;
  }

  .hero-content {
    max-width: 720px;
  }

  .hero-content .badge {
    margin-bottom: 16px;
  }

  .hero-content h1 {
    margin: 16px 0 12px;
    font-size: clamp(2rem, 4vw, 2.75rem);
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 600px;
  }

  /* ===== Calculator Layout ===== */
  .tool-section {
    padding-bottom: 64px;
  }

  .calc-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 32px;
    align-items: start;
  }

  /* ===== Panel Card ===== */
  .panel-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 28px;
    margin-bottom: 20px;
  }

  .panel-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 24px;
    color: var(--color-text);
  }

  .panel-title svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  /* ===== Slider Groups ===== */
  .slider-group {
    margin-bottom: 28px;
  }

  .slider-group:last-child {
    margin-bottom: 0;
  }

  .slider-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 4px;
  }

  .slider-label {
