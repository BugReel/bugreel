    'functional', 'ui-ux', 'performance', 'security', 'accessibility',
    'cross-browser', 'responsive', 'api-testing', 'auth',
    'data-validation', 'error-handling', 'localization',
  ];

  // --- State ---
  let selectedAppType: AppType | null = null;
  let selectedCategories: Set<CategoryKey> = new Set();
  let checkedItems: Set<string> = new Set();

  // --- DOM ---
  const appTypeGrid = document.getElementById('app-type-grid')!;
  const categoryGrid = document.getElementById('category-grid')!;
  const step2 = document.getElementById('step-2')!;
  const step3 = document.getElementById('step-3')!;
  const checklistOutput = document.getElementById('checklist-output')!;
  const progressBarFill = document.getElementById('progress-bar-fill')!;
  const progressLabel = document.getElementById('progress-label')!;
  const copyMdBtn = document.getElementById('copy-md-btn')!;
  const copyMdText = document.getElementById('copy-md-text')!;
  const downloadMdBtn = document.getElementById('download-md-btn')!;
  const resetBtn = document.getElementById('reset-btn')!;
  const selectAllBtn = document.getElementById('select-all-btn')!;

  const appTypeCards = appTypeGrid.querySelectorAll('.app-type-card');
  const categoryCards = categoryGrid.querySelectorAll('.category-card');

  // --- localStorage ---
  function saveState() {
    try {
      const state = {
        appType: selectedAppType,
        categories: Array.from(selectedCategories),
        checked: Array.from(checkedItems),
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch (e) { /* silent */ }
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const state = JSON.parse(raw);

      if (state.appType && ['web', 'mobile', 'api', 'desktop'].includes(state.appType)) {
        selectedAppType = state.appType;
        appTypeCards.forEach(card => {
          card.classList.toggle('selected', (card as HTMLElement).dataset.type === selectedAppType);
        });
        step2.classList.remove('step-disabled');
        step2.classList.add('step-active');
      }

      if (state.categories && Array.isArray(state.categories)) {
        state.categories.forEach((c: string) => selectedCategories.add(c as CategoryKey));
        categoryCards.forEach(card => {
          card.classList.toggle('selected', selectedCategories.has((card as HTMLElement).dataset.category as CategoryKey));
        });
      }

      if (state.checked && Array.isArray(state.checked)) {
        state.checked.forEach((id: string) => checkedItems.add(id));
      }

      updateSelectAllBtn();

      if (selectedAppType && selectedCategories.size > 0) {
        step3.classList.remove('step-disabled');
        step3.classList.add('step-active');
        renderChecklist();
      }
    } catch (e) { /* silent */ }
  }

  // --- App Type Selection ---
  appTypeCards.forEach(card => {
    card.addEventListener('click', () => {
      const type = (card as HTMLElement).dataset.type as AppType;

      // If changing app type, reset checked items since items change
      if (selectedAppType !== type) {
        checkedItems.clear();
      }

      selectedAppType = type;
      appTypeCards.forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');

      // Enable step 2
      step2.classList.remove('step-disabled');
      step2.classList.add('step-active');

      // If categories were selected, re-render
      if (selectedCategories.size > 0) {
        step3.classList.remove('step-disabled');
        step3.classList.add('step-active');
        renderChecklist();
      }

      saveState();
    });
  });

  // --- Category Selection ---
  categoryCards.forEach(card => {
    card.addEventListener('click', () => {
      const cat = (card as HTMLElement).dataset.category as CategoryKey;

      if (selectedCategories.has(cat)) {
        selectedCategories.delete(cat);
        card.classList.remove('selected');
      } else {
        selectedCategories.add(cat);
        card.classList.add('selected');
      }

      updateSelectAllBtn();

      if (selectedCategories.size > 0 && selectedAppType) {
        step3.classList.remove('step-disabled');
        step3.classList.add('step-active');
        renderChecklist();
      } else {
        step3.classList.remove('step-active');
        step3.classList.add('step-disabled');
        checklistOutput.innerHTML = '';
        updateProgress(0, 0);
      }

      saveState();
    });
  });

  // --- Select All / Deselect All ---
  selectAllBtn.addEventListener('click', () => {
    const allSelected = selectedCategories.size === CATEGORY_ORDER.length;
    if (allSelected) {
      selectedCategories.clear();
      categoryCards.forEach(c => c.classList.remove('selected'));
    } else {
      CATEGORY_ORDER.forEach(c => selectedCategories.add(c));
      categoryCards.forEach(c => c.classList.add('selected'));
    }

    updateSelectAllBtn();

    if (selectedCategories.size > 0 && selectedAppType) {
      step3.classList.remove('step-disabled');
      step3.classList.add('step-active');
      renderChecklist();
    } else {
      step3.classList.remove('step-active');
      step3.classList.add('step-disabled');
      checklistOutput.innerHTML = '';
      updateProgress(0, 0);
    }

    saveState();
  });

  function updateSelectAllBtn() {
    const allSelected = selectedCategories.size === CATEGORY_ORDER.length;
    selectAllBtn.textContent = allSelected ? 'Deselect All' : 'Select All';
  }

  // --- Render Checklist ---
  function getAllItems(): ChecklistItem[] {
    if (!selectedAppType) return [];
    const items: ChecklistItem[] = [];
    CATEGORY_ORDER.forEach(catKey => {
      if (!selectedCategories.has(catKey)) return;
      const cat = CATEGORIES[catKey];
      const catItems = cat.items[selectedAppType!] || [];
      catItems.forEach((text, idx) => {
        const id = `${catKey}-${idx}`;
        items.push({ id, text, checked: checkedItems.has(id) });
      });
    });
    return items;
  }

  function renderChecklist() {
    if (!selectedAppType || selectedCategories.size === 0) {
      checklistOutput.innerHTML = '';
      updateProgress(0, 0);
      return;
    }

    let html = '';
    let totalItems = 0;
    let checkedCount = 0;

    CATEGORY_ORDER.forEach(catKey => {
      if (!selectedCategories.has(catKey)) return;
      const cat = CATEGORIES[catKey];
      const items = cat.items[selectedAppType!] || [];
      if (items.length === 0) return;

      let sectionChecked = 0;
      items.forEach((_, idx) => {
        const id = `${catKey}-${idx}`;
        if (checkedItems.has(id)) sectionChecked++;
      });

      totalItems += items.length;
      checkedCount += sectionChecked;

      html += `<div class="cl-section" data-category="${catKey}">`;
      html += `<div class="cl-section-header" data-toggle="${catKey}">`;
      html += `<svg class="cl-section-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      html += `<span class="cl-section-title">${cat.label}</span>`;
      html += `<span class="cl-section-count" data-count="${catKey}">${sectionChecked}/${items.length}</span>`;
      html += `</div>`;
      html += `<div class="cl-section-body" data-body="${catKey}">`;

      items.forEach((text, idx) => {
        const id = `${catKey}-${idx}`;
        const isChecked = checkedItems.has(id);
        html += `<div class="cl-item${isChecked ? ' checked' : ''}" data-id="${id}">`;
        html += `<div class="cl-checkbox">`;
        html += `<svg class="cl-checkmark" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2.5 6l2.5 2.5 4.5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        html += `</div>`;
        html += `<span class="cl-text">${escapeHtml(text)}</span>`;
        html += `</div>`;
      });

      html += `</div></div>`;
    });

    checklistOutput.innerHTML = html;
    updateProgress(checkedCount, totalItems);

    // Bind click events for items
    checklistOutput.querySelectorAll('.cl-item').forEach(item => {
      item.addEventListener('click', () => {
        const id = (item as HTMLElement).dataset.id!;
        if (checkedItems.has(id)) {
          checkedItems.delete(id);
          item.classList.remove('checked');
        } else {
          checkedItems.add(id);
          item.classList.add('checked');
        }
        updateProgressFromDOM();
        saveState();
      });
    });

    // Bind click events for section collapse
    checklistOutput.querySelectorAll('.cl-section-header').forEach(header => {
      header.addEventListener('click', () => {
        const catKey = (header as HTMLElement).dataset.toggle!;
        const body = checklistOutput.querySelector(`[data-body="${catKey}"]`) as HTMLElement;
        if (!body) return;
        const isCollapsed = body.classList.contains('collapsed');
        if (isCollapsed) {
          body.classList.remove('collapsed');
          header.classList.remove('collapsed');
        } else {
          body.classList.add('collapsed');
          header.classList.add('collapsed');
        }
      });
    });
  }

  // --- Progress ---
  function updateProgress(checked: number, total: number) {
    const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
    progressBarFill.style.width = `${pct}%`;

    progressBarFill.classList.remove('progress-mid', 'progress-high');
    if (pct >= 100) {
      progressBarFill.classList.add('progress-high');
    } else if (pct >= 50) {
      progressBarFill.classList.add('progress-mid');
    }

    progressLabel.textContent = `${checked} / ${total} items checked`;
  }

  function updateProgressFromDOM() {
    const allItems = checklistOutput.querySelectorAll('.cl-item');
    const checkedCount = checklistOutput.querySelectorAll('.cl-item.checked').length;
    updateProgress(checkedCount, allItems.length);

    // Update section counts
    CATEGORY_ORDER.forEach(catKey => {
      if (!selectedCategories.has(catKey)) return;
      const section = checklistOutput.querySelector(`[data-category="${catKey}"]`);
      if (!section) return;
      const items = section.querySelectorAll('.cl-item');
      const checked = section.querySelectorAll('.cl-item.checked');
      const countEl = section.querySelector(`[data-count="${catKey}"]`);
      if (countEl) {
        countEl.textContent = `${checked.length}/${items.length}`;
      }
    });
  }

  // --- Generate Markdown ---
  function generateMarkdown(): string {
    if (!selectedAppType || selectedCategories.size === 0) return '';

    const appLabels: Record<AppType, string> = {
      web: 'Web Application',
      mobile: 'Mobile App (iOS/Android)',
      api: 'API / Backend',
      desktop: 'Desktop Application',
    };

    let md = `# QA Checklist -- ${appLabels[selectedAppType]}\n\n`;

    CATEGORY_ORDER.forEach(catKey => {
      if (!selectedCategories.has(catKey)) return;
      const cat = CATEGORIES[catKey];
      const items = cat.items[selectedAppType!] || [];
      if (items.length === 0) return;

      md += `## ${cat.label}\n\n`;
      items.forEach((text, idx) => {
        const id = `${catKey}-${idx}`;
        const mark = checkedItems.has(id) ? 'x' : ' ';
        md += `- [${mark}] ${text}\n`;
      });
      md += '\n';
    });

    md += `---\n*Generated with [BugReel QA Checklist Generator](https://bugreel.io/tools/qa-checklist)*\n`;
    return md;
  }

  // --- Copy ---
  copyMdBtn.addEventListener('click', async () => {
    const md = generateMarkdown();
    if (!md) return;
    try {
      await navigator.clipboard.writeText(md);
      copyMdBtn.classList.add('copied');
      copyMdText.textContent = 'Copied!';
      setTimeout(() => {
        copyMdBtn.classList.remove('copied');
        copyMdText.textContent = 'Copy as Markdown';
      }, 2000);
    } catch {
      const textArea = document.createElement('textarea');
      textArea.value = md;
      textArea.style.position = 'fixed';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      copyMdBtn.classList.add('copied');
      copyMdText.textContent = 'Copied!';
      setTimeout(() => {
        copyMdBtn.classList.remove('copied');
        copyMdText.textContent = 'Copy as Markdown';
      }, 2000);
    }
  });

  // --- Download ---
  downloadMdBtn.addEventListener('click', () => {
    const md = generateMarkdown();
    if (!md) return;
    const appSlug = selectedAppType || 'checklist';
    const filename = `qa-checklist-${appSlug}.md`;
    const blob = new Blob([md], { type: 'text/markdown;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // --- Reset ---
  resetBtn.addEventListener('click', () => {
    checkedItems.clear();
    checklistOutput.querySelectorAll('.cl-item.checked').forEach(item => {
      item.classList.remove('checked');
    });
    updateProgressFromDOM();
    saveState();
  });

  // --- Helpers ---
  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  // --- Init ---
  loadState();
</script>
