  }

  .explanation-prose {
    max-width: 720px;
    margin: 0 auto;
  }

  .explanation-prose p {
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .explanation-prose p:last-child {
