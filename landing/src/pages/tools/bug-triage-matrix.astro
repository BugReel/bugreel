  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 24px 0 32px;
    }

    .tips-grid {
      grid-template-columns: 1fr;
    }

    .summary-header {
      flex-direction: column;
      align-items: flex-start;
    }

    /* Matrix becomes list on mobile */
    .matrix-wrapper {
      flex-direction: column;
    }

    .matrix-y-label {
      display: none;
    }

    .matrix-x-label {
      display: none;
    }

    .matrix-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: 0;
    }

    .matrix-cell {
      min-height: 80px;
    }

    .matrix-cell::before {
      font-size: 0.625rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      opacity: 0.6;
      margin-bottom: 4px;
    }

    .cell-fix-now::before { content: "High Severity + High Impact"; }
    .cell-schedule::before { content: "High Severity + Low Impact"; }
    .cell-plan::before { content: "Low Severity + High Impact"; }
    .cell-backlog::before { content: "Low Severity + Low Impact"; }

    .summary-table th:nth-child(5),
    .summary-table td:nth-child(5) {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .summary-table th:nth-child(3),
    .summary-table td:nth-child(3) {
      display: none;
    }
