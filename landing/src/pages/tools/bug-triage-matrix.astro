</style>

<script>
  // ===== Bug Triage Matrix — Client-Side Logic =====

  // --- Types ---
  interface Bug {
    id: string;
    title: string;
    severity: string;
    impact: string;
    cell: string;
  }

  // --- Constants ---
  const SEVERITY_MAP: Record<string, { label: string; dotClass: string; order: number }> = {
    critical: { label: 'Critical', dotClass: 'dot-critical', order: 0 },
    high: { label: 'High', dotClass: 'dot-high', order: 1 },
    medium: { label: 'Medium', dotClass: 'dot-medium', order: 2 },
    low: { label: 'Low', dotClass: 'dot-low', order: 3 },
  };

  const IMPACT_MAP: Record<string, { label: string; order: number }> = {
    revenue: { label: 'Revenue / Security', order: 0 },
    core: { label: 'Core Workflow', order: 1 },
    secondary: { label: 'Secondary Feature', order: 2 },
    cosmetic: { label: 'Cosmetic', order: 3 },
  };

  const CELL_MAP: Record<string, { action: string; actionClass: string; assignee: string }> = {
    'fix-now': { action: 'Fix Now', actionClass: 'action-fix-now', assignee: 'Senior Dev / On-call' },
    schedule: { action: 'Schedule', actionClass: 'action-schedule', assignee: 'Senior Dev' },
    plan: { action: 'Plan', actionClass: 'action-plan', assignee: 'Product Owner' },
    backlog: { action: 'Backlog', actionClass: 'action-backlog', assignee: 'Junior Dev / QA' },
  };

  // --- State ---
  let bugs: Bug[] = [];
  let draggedBugId: string | null = null;

  // --- DOM ---
  const titleInput = document.getElementById('bug-title') as HTMLInputElement;
  const severitySelect = document.getElementById('bug-severity') as HTMLSelectElement;
  const impactSelect = document.getElementById('bug-impact') as HTMLSelectElement;
  const addBtn = document.getElementById('add-bug-btn')!;
  const formError = document.getElementById('form-error')!;
  const matrixEmpty = document.getElementById('matrix-empty')!;
  const triageSummary = document.getElementById('triage-summary')!;
  const summaryTbody = document.getElementById('summary-tbody')!;
  const copyReportBtn = document.getElementById('copy-report-btn')!;
  const copyReportText = document.getElementById('copy-report-text')!;
  const clearAllBtn = document.getElementById('clear-all-btn')!;

  const cellElements: Record<string, HTMLElement> = {
    'fix-now': document.getElementById('cell-fix-now')!,
    schedule: document.getElementById('cell-schedule')!,
    plan: document.getElementById('cell-plan')!,
    backlog: document.getElementById('cell-backlog')!,
  };

  const matrixCells = document.querySelectorAll('.matrix-cell') as NodeListOf<HTMLElement>;
  const quickAddBtns = document.querySelectorAll('.quick-add-btn') as NodeListOf<HTMLButtonElement>;

  // --- Helpers ---
  function generateId(): string {
    return 'bug-' + Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 7);
  }

  function classifyBug(severity: string, impact: string): string {
    const isHighSev = severity === 'critical' || severity === 'high';
    const isHighImpact = impact === 'revenue' || impact === 'core';

    if (isHighSev && isHighImpact) return 'fix-now';
    if (isHighSev && !isHighImpact) return 'schedule';
    if (!isHighSev && isHighImpact) return 'plan';
    return 'backlog';
  }

  function showError(msg: string) {
    formError.textContent = msg;
    formError.hidden = false;
    setTimeout(() => { formError.hidden = true; }, 3000);
  }

  // --- Add Bug ---
  function addBug(title: string, severity: string, impact: string) {
    const cell = classifyBug(severity, impact);
    const bug: Bug = { id: generateId(), title, severity, impact, cell };
    bugs.push(bug);
    render();
  }

  // --- Remove Bug ---
  function removeBug(id: string) {
    bugs = bugs.filter(b => b.id !== id);
    render();
  }

  // --- Move Bug to Cell ---
  function moveBugToCell(id: string, newCell: string) {
    const bug = bugs.find(b => b.id === id);
    if (bug) {
      bug.cell = newCell;
      render();
    }
  }

  // --- Render ---
  function render() {
    // Clear cells
    Object.values(cellElements).forEach(el => { el.innerHTML = ''; });

    // Update counts
    const counts: Record<string, number> = { 'fix-now': 0, schedule: 0, plan: 0, backlog: 0 };
    bugs.forEach(b => { counts[b.cell] = (counts[b.cell] || 0) + 1; });

    Object.keys(counts).forEach(cell => {
      const countEl = document.querySelector(`[data-count="${cell}"]`);
      if (countEl) {
        const n = counts[cell];
        countEl.textContent = n === 1 ? '1 bug' : `${n} bugs`;
      }
    });

    // Render pills in cells
    bugs.forEach(bug => {
      const container = cellElements[bug.cell];
      if (!container) return;

      const pill = document.createElement('div');
      pill.className = 'bug-pill';
      pill.draggable = true;
      pill.dataset.bugId = bug.id;

      const sevInfo = SEVERITY_MAP[bug.severity];

      pill.innerHTML = `
        <span class="bug-pill-dot ${sevInfo ? sevInfo.dotClass : ''}"></span>
        <span class="bug-pill-text" title="${bug.title}">${bug.title}</span>
        <button class="bug-pill-remove" type="button" aria-label="Remove bug" data-remove-id="${bug.id}">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 3l6 6M9 3l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
      `;

      container.appendChild(pill);
    });

    // Wire pill drag events
    document.querySelectorAll('.bug-pill').forEach(pill => {
      pill.addEventListener('dragstart', handlePillDragStart as EventListener);
      pill.addEventListener('dragend', handlePillDragEnd as EventListener);
    });

    // Wire remove buttons
    document.querySelectorAll('.bug-pill-remove').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.removeId;
        if (id) removeBug(id);
      });
    });

    // Empty state
    matrixEmpty.hidden = bugs.length > 0;

    // Summary
    if (bugs.length > 0) {
      triageSummary.hidden = false;
      renderSummary();
    } else {
      triageSummary.hidden = true;
    }
  }

  function renderSummary() {
    summaryTbody.innerHTML = '';

    // Sort: fix-now first, then schedule, plan, backlog
    const cellOrder: Record<string, number> = { 'fix-now': 0, schedule: 1, plan: 2, backlog: 3 };
    const sorted = [...bugs].sort((a, b) => (cellOrder[a.cell] ?? 4) - (cellOrder[b.cell] ?? 4));

    sorted.forEach(bug => {
      const sevInfo = SEVERITY_MAP[bug.severity];
      const impInfo = IMPACT_MAP[bug.impact];
      const cellInfo = CELL_MAP[bug.cell];

      const row = document.createElement('tr');
      row.innerHTML = `
        <td title="${bug.title}">${bug.title}</td>
        <td>
          <span class="summary-sev">
            <span class="sev-dot ${sevInfo ? 'sev-dot--' + bug.severity : ''}"></span>
            ${sevInfo ? sevInfo.label : bug.severity}
          </span>
        </td>
        <td>${impInfo ? impInfo.label : bug.impact}</td>
        <td><span class="summary-action-badge ${cellInfo ? cellInfo.actionClass : ''}">${cellInfo ? cellInfo.action : bug.cell}</span></td>
        <td>${cellInfo ? cellInfo.assignee : '---'}</td>
        <td>
          <button class="summary-remove-btn" type="button" aria-label="Remove" data-summary-remove="${bug.id}">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 3l6 6M9 3l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </td>
      `;
      summaryTbody.appendChild(row);
    });

    // Wire summary remove buttons
    document.querySelectorAll('.summary-remove-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.summaryRemove;
        if (id) removeBug(id);
      });
    });
  }

  // --- Drag & Drop ---
  function handlePillDragStart(e: DragEvent) {
    const pill = (e.target as HTMLElement).closest('.bug-pill') as HTMLElement;
    if (!pill) return;
    draggedBugId = pill.dataset.bugId || null;
    pill.classList.add('dragging');
    if (e.dataTransfer) {
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', draggedBugId || '');
    }
  }

  function handlePillDragEnd(e: DragEvent) {
    const pill = (e.target as HTMLElement).closest('.bug-pill') as HTMLElement;
    if (pill) pill.classList.remove('dragging');
    draggedBugId = null;
    matrixCells.forEach(c => c.classList.remove('drag-over'));
  }

  matrixCells.forEach(cell => {
    cell.addEventListener('dragover', (e: Event) => {
      const de = e as DragEvent;
      de.preventDefault();
      if (de.dataTransfer) de.dataTransfer.dropEffect = 'move';
      cell.classList.add('drag-over');
    });

    cell.addEventListener('dragleave', () => {
      cell.classList.remove('drag-over');
    });

    cell.addEventListener('drop', (e: Event) => {
      const de = e as DragEvent;
      de.preventDefault();
      cell.classList.remove('drag-over');
      const bugId = de.dataTransfer?.getData('text/plain') || draggedBugId;
      const targetCell = cell.dataset.cell;
      if (bugId && targetCell) {
        moveBugToCell(bugId, targetCell);
      }
    });
  });

  // --- Add Bug Button ---
  addBtn.addEventListener('click', () => {
    const title = titleInput.value.trim();
    const severity = severitySelect.value;
    const impact = impactSelect.value;

    if (!title) { showError('Enter a bug title or description.'); titleInput.focus(); return; }
    if (!severity) { showError('Select a severity level.'); return; }
    if (!impact) { showError('Select a business impact.'); return; }

    addBug(title, severity, impact);

    // Reset form
    titleInput.value = '';
    severitySelect.value = '';
    impactSelect.value = '';
    formError.hidden = true;
    titleInput.focus();
  });

  // Enter key on title input
  titleInput.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      addBtn.click();
    }
  });

  // --- Quick Add ---
  quickAddBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const title = btn.dataset.title || '';
      const severity = btn.dataset.severity || '';
      const impact = btn.dataset.impact || '';
      if (title && severity && impact) {
        addBug(title, severity, impact);
        btn.classList.add('used');
      }
    });
  });

  // --- Copy Report ---
  function buildReport(): string {
    const cellOrder: Record<string, number> = { 'fix-now': 0, schedule: 1, plan: 2, backlog: 3 };
    const sorted = [...bugs].sort((a, b) => (cellOrder[a.cell] ?? 4) - (cellOrder[b.cell] ?? 4));

    let md = '# Bug Triage Report\n\n';
    md += '| Bug | Severity | Impact | Action | Assignee |\n';
    md += '|-----|----------|--------|--------|----------|\n';

    sorted.forEach(bug => {
      const sevInfo = SEVERITY_MAP[bug.severity];
      const impInfo = IMPACT_MAP[bug.impact];
      const cellInfo = CELL_MAP[bug.cell];
      md += `| ${bug.title} | ${sevInfo ? sevInfo.label : bug.severity} | ${impInfo ? impInfo.label : bug.impact} | ${cellInfo ? cellInfo.action : bug.cell} | ${cellInfo ? cellInfo.assignee : '---'} |\n`;
    });

    md += `\n---\nGenerated with BugReel Bug Triage Matrix (https://bugreel.io/tools/bug-triage-matrix)`;
    return md;
  }

  copyReportBtn.addEventListener('click', async () => {
    if (bugs.length === 0) return;
    const text = buildReport();
    try {
      await navigator.clipboard.writeText(text);
      copyReportBtn.classList.add('copied');
      copyReportText.textContent = 'Copied!';
      setTimeout(() => {
        copyReportBtn.classList.remove('copied');
        copyReportText.textContent = 'Copy Triage Report';
      }, 2000);
    } catch {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
      copyReportBtn.classList.add('copied');
      copyReportText.textContent = 'Copied!';
      setTimeout(() => {
        copyReportBtn.classList.remove('copied');
        copyReportText.textContent = 'Copy Triage Report';
      }, 2000);
    }
  });

  // --- Clear All ---
  clearAllBtn.addEventListener('click', () => {
    bugs = [];
    render();
    // Reset quick-add buttons
    quickAddBtns.forEach(btn => btn.classList.remove('used'));
    // Scroll to top of tool
    document.querySelector('.tool-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // --- Initial Render ---
  render();
</script>
