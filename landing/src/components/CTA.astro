---
import strings from '../i18n/en.json';

const c = strings.cta;
---

<section class="cta-section section">
  <div class="container">
    <div class="cta-inner">
      <div class="cta-glow" aria-hidden="true"></div>
      <h2>{c.title}</h2>
      <p>{c.subtitle}</p>
      <div class="cta-actions">
        <a href="https://github.com/BugReel/bugreel" class="btn btn-primary btn-lg">{c.ctaPrimary}</a>
        <a href="https://docs.bugreel.io" class="btn btn-secondary btn-lg" target="_blank" rel="noopener">{c.ctaSecondary}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 48px 0 96px;
  }

  .cta-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 24px;
    padding: 80px 40px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .cta-inner h2 {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    position: relative;
    z-index: 1;
  }

  .cta-inner p {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 480px;
    position: relative;
    z-index: 1;
  }

  .cta-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .cta-glow {
    position: absolute;
    top: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(99, 102, 241, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  @media (max-width: 768px) {
    .cta-inner {
      padding: 48px 24px;
    }

    .cta-actions {
      flex-direction: column;
      width: 100%;
    }

    .cta-actions .btn {
      width: 100%;
    }
  }
</style>
