---
import strings from '../i18n/en.json';

const t = strings.integrations;

const integrations = [
  {
    name: t.jira,
    logo: `<svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M11.571 11.513H0a5.218 5.218 0 0 0 5.232 5.215h2.13v2.057A5.215 5.215 0 0 0 12.575 24V12.518a1.005 1.005 0 0 0-1.005-1.005zm5.723-5.756H5.736a5.215 5.215 0 0 0 5.215 5.214h2.129v2.058a5.218 5.218 0 0 0 5.215 5.214V6.762a1.005 1.005 0 0 0-1.001-1.005zM23 .249H11.443a5.215 5.215 0 0 0 5.214 5.214h2.129v2.058A5.218 5.218 0 0 0 24 12.735V1.254A1.005 1.005 0 0 0 23 .249z"/></svg>`,
    color: '#2684FF',
    teamOnly: true,
  },
  {
    name: t.linear,
    logo: `<svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M2.088 14.38a.5.5 0 0 1-.057-.58l3.594-5.923a.5.5 0 0 1 .738-.144l13.77 10.1a.5.5 0 0 1-.138.86l-6.69 2.59a.5.5 0 0 1-.374-.003L2.088 14.38zm-.38-3.415a.5.5 0 0 1 .068-.636L8.81 3.303a.5.5 0 0 1 .757.098l10.49 16.427a.5.5 0 0 1-.473.743H13.56a.5.5 0 0 1-.322-.117L1.708 10.965z"/></svg>`,
    color: '#5E6AD2',
    teamOnly: true,
  },
  {
    name: t.github,
    logo: `<svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
    color: '#ffffff',
    teamOnly: true,
  },
  {
    name: t.youtrack,
    logo: `<svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M3 3h18v18H3V3zm2.4 13.2h7.2v1.2H5.4v-1.2zm0-2.4h9.6v1.2H5.4v-1.2z"/></svg>`,
    color: '#8052ff',
    teamOnly: false,
  },
  {
    name: t.webhook,
    logo: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="32" height="32" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
    color: '#22d3ee',
    teamOnly: false,
  },
];
---

<section class="section section-sm" id="integrations">
  <div class="container">
    <div class="section-header">
      <h2>{t.title}</h2>
      <p>{t.subtitle}</p>
    </div>

    <div class="integrations-grid">
      {integrations.map((integration) => (
        <div class="integration-card card">
          <div class="integration-icon" style={`color: ${integration.color}`}>
            <Fragment set:html={integration.logo} />
          </div>
          <span class="integration-name">
            {integration.name}
            {integration.teamOnly && <span class="integration-badge">Team</span>}
          </span>
        </div>
      ))}
      <div class="integration-card card integration-coming">
        <div class="integration-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
        </div>
        <span class="integration-name">{t.moreComing}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .integrations-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 20px;
  }

  .integration-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 32px 16px;
    text-align: center;
  }

  .integration-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--color-text-muted);
  }

  .integration-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .integration-badge {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 4px;
    padding: 1px 6px;
  }

  .integration-coming {
    border-style: dashed;
    opacity: 0.6;
  }

  .integration-coming .integration-icon {
    color: var(--color-text-dim);
  }

  .integration-coming .integration-name {
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .integrations-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .integrations-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
