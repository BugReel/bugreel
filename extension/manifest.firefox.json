{
  "manifest_version": 3,
  "name": "BugReel",
  "version": "1.5.1",
  "description": "Record browser tab, window or screen with microphone and upload bug reports",
  "permissions": [
    "tabs",
    "storage",
    "notifications",
    "webRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script-errors.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-script-widget.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-script-actions.js"],
      "run_at": "document_end",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script-server-bridge.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "mark-screenshot": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Mark screenshot timecode"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bugreel@bugreel.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["websiteContent"],
        "optional": ["technicalAndInteraction"]
      }
    }
  }
}
